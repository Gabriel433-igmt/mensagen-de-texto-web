  if (selectedGroupMembers.length < 1) { document.getElementById('group-error-text').textContent = 'Adicione ao menos 1 membro.'; document.getElementById('group-error').classList.add('show'); return; }
 
  const participantIds = [currentUser.uid, ...selectedGroupMembers.map(m => m.uid)];
