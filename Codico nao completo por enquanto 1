// ============================================================
function openEditProfileModal() {
  document.getElementById('edit-name-input').value  = currentUserData.name || '';
  document.getElementById('edit-about-input').value = currentUserData.about || '';
  document.getElementById('edit-profile-error').classList.remove('show');
  openModal('edit-profile-modal');
}
 
async function saveProfile() {
  const name  = document.getElementById('edit-name-input').value.trim();
  const about = document.getElementById('edit-about-input').value.trim();
 
  if (!name || name.length < 2) {
    document.getElementById('edit-profile-error-text').textContent = 'Nome muito curto.';
    document.getElementById('edit-profile-error').classList.add('show');
    return;
  }
  if (isLucasDetected(name) || isLucasDetected(about)) {
    document.getElementById('edit-profile-error-text').textContent = '🚫 Conteúdo proibido detectado.';
    document.getElementById('edit-profile-error').classList.add('show');
    return;
  }
 
  try {
    await db.collection('users').doc(currentUser.uid).update({ name, about });
    currentUserData.name  = name;
    currentUserData.about = about;
    applyAvatar(document.getElementById('my-avatar-sidebar'), name);
    closeModal('edit-profile-modal');
    showToast('Perfil atualizado!', '', 'success');
  } catch (e) {
    document.getElementById('edit-profile-error-text').textContent = e.message;
    document.getElementById('edit-profile-error').classList.add('show');
  }
}
 
