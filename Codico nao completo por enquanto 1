// ============================================================
// SECURITY: LUCAS BAN SYSTEM — COMPREHENSIVE DETECTION
// ============================================================
const LUCAS_PATTERNS = [
  // Direct matches
  /\blucas?\b/i,
  /\blucaz\b/i,
  /\blukaz?\b/i,
  /\blukas?\b/i,
  // Abbreviations
  /\blcs\b/i,
  /\bluc\b/i,
  /\bL\.C\.S\b/i,
  // Leet speak variants
  /l[4@]c[4@]s/i,
  /l[u\u00FC][ck][4@]s/i,
  /luk4s/i,
  /luc4s/i,
  /l\u00FAc\u00E3s/i,  // lúcãs unicode
  // Spaced / separated
  /l[\s\-_\.\/\\|]+u[\s\-_\.\/\\|]+c[\s\-_\.\/\\|]+a[\s\-_\.\/\\|]+s/i,
  /l[\s\-_\.\/\\|]+u[\s\-_\.\/\\|]+c[\s\-_\.\/\\|]+a/i,
  // Reversed (sacul)
  /\bsacul\b/i,
  // Single letter + numbers combos that spell lucas
  /l1u2c3a4s5/i,
  // Zero-width / unicode tricks
  /l\u200Bu/i,
  // Username-style
  /lucas[_\-\.\d]*/i,
  /[_\-\.]lucas/i,
  // Common shortcuts
  /^lc$/i,
  /^lu$/i,
  /^lca$/i,
];
 
/**
 * Returns true if the text contains a Lucas pattern.
 * Strips zero-width chars and normalizes before checking.
 */
function isLucasDetected(text) {
  if (!text) return false;
  // Strip zero-width characters
  const clean = text
    .replace(/[\u200B-\u200D\uFEFF\u00AD]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  for (const p of LUCAS_PATTERNS) {
    if (p.test(clean)) return true;
  }
  return false;
}
 
