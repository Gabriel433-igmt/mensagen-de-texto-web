<style>
/* ============================================================
   DESIGN SYSTEM — CSS VARIABLES & RESET
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
:root {
  /* Color palette — deep teal/slate dark theme */
  --bg-root:        #0b1117;
  --bg-panel:       #161f27;
  --bg-sidebar:     #131b22;
  --bg-hover:       #1e2d38;
  --bg-active:      #1a2d3a;
  --bg-input:       #1e2d38;
  --bg-msg-out:     #0b5940;
  --bg-msg-in:      #1e2d38;
  --bg-modal:       #1a2630;
  --bg-overlay:     rgba(0,0,0,0.75);
  --bg-search:      #0f1923;
  --bg-tooltip:     #0f1923;
  --bg-reaction:    #243341;
 
  /* Text */
  --text-primary:   #e8edf2;
  --text-secondary: #8a9bb0;
  --text-muted:     #566b7c;
  --text-time:      #7a8fa0;
  --text-link:      #4db8a0;
 
  /* Accent */
  --accent:         #00c896;
  --accent-dark:    #009e78;
  --accent-glow:    rgba(0,200,150,0.18);
  --accent-border:  rgba(0,200,150,0.3);
 
  /* Danger/warn */
  --danger:         #ff5470;
  --danger-dark:    #cc2244;
  --danger-glow:    rgba(255,84,112,0.15);
  --warn:           #ffb830;
  --warn-glow:      rgba(255,184,48,0.15);
  --info:           #4db8ff;
 
  /* Borders */
  --border:         rgba(255,255,255,0.06);
  --border-strong:  rgba(255,255,255,0.12);
  --border-accent:  rgba(0,200,150,0.25);
 
  /* Layout */
  --sidebar-w:      370px;
  --header-h:       62px;
  --input-area-h:   68px;
 
  /* Radius */
  --r-xs: 4px; --r-sm: 8px; --r-md: 12px; --r-lg: 18px; --r-xl: 24px; --r-full: 9999px;
 
  /* Typography */
  --font:      'Sora', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
 
  /* Shadows */
  --shadow-sm: 0 1px 6px rgba(0,0,0,0.4);
  --shadow-md: 0 4px 20px rgba(0,0,0,0.5);
  --shadow-lg: 0 8px 40px rgba(0,0,0,0.65);
  --shadow-accent: 0 0 20px rgba(0,200,150,0.25);
 
  /* Transitions */
  --t-fast: 0.14s ease;
  --t-mid:  0.22s ease;
  --t-slow: 0.35s ease;
}
 
/* ============================================================
   BASE
   ============================================================ */
html, body { height: 100%; overflow: hidden; }
body {
  font-family: var(--font);
  background: var(--bg-root);
  color: var(--text-primary);
  font-size: 14.5px;
  line-height: 1.45;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
a { color: var(--text-link); text-decoration: none; }
button, input, textarea, select {
  font-family: var(--font);
  font-size: inherit;
}
button { cursor: pointer; }
img { max-width: 100%; border-radius: var(--r-sm); }
 
/* ============================================================
   SCROLLBARS
   ============================================================ */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.18); }
 
/* ============================================================
   UTILITY
   ============================================================ */
.hidden    { display: none !important; }
.flex      { display: flex; }
.flex-col  { display: flex; flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.gap-8  { gap: 8px; }
.gap-12 { gap: 12px; }
.gap-16 { gap: 16px; }
.flex-1 { flex: 1; min-width: 0; }
.text-center { text-align: center; }
.truncate { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.mt-4  { margin-top: 4px; }
.mt-8  { margin-top: 8px; }
.mt-12 { margin-top: 12px; }
.mt-16 { margin-top: 16px; }
.mb-8  { margin-bottom: 8px; }
.fw-600 { font-weight: 600; }
.fw-700 { font-weight: 700; }
.fs-12 { font-size: 12px; }
.fs-13 { font-size: 13px; }
.color-secondary { color: var(--text-secondary); }
.color-accent    { color: var(--accent); }
.color-danger    { color: var(--danger); }
.color-warn      { color: var(--warn); }
 
/* ============================================================
   LOADING SPINNER
   ============================================================ */
.spinner {
  width: 24px; height: 24px;
  border: 2.5px solid rgba(255,255,255,0.1);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  flex-shrink: 0;
}
@keyframes spin { to { transform: rotate(360deg); } }
 
.dots-loader { display: flex; gap: 5px; align-items: center; justify-content: center; padding: 20px; }
.dots-loader span {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--accent); opacity: 0.3;
  animation: dotPulse 1.3s infinite ease-in-out;
}
.dots-loader span:nth-child(2) { animation-delay: 0.18s; }
.dots-loader span:nth-child(3) { animation-delay: 0.36s; }
@keyframes dotPulse { 0%,80%,100% { opacity: 0.2; transform: scale(0.8); } 40% { opacity: 1; transform: scale(1); } }
 
/* ============================================================
   BUTTONS
   ============================================================ */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 7px;
  padding: 10px 20px; border: none; border-radius: var(--r-md);
  font-weight: 600; font-size: 14px; transition: all var(--t-fast);
  white-space: nowrap; position: relative; overflow: hidden;
}
.btn:active { transform: scale(0.97); }
.btn-primary {
  background: var(--accent); color: #fff;
  box-shadow: 0 2px 12px rgba(0,200,150,0.3);
}
.btn-primary:hover { background: var(--accent-dark); box-shadow: 0 4px 18px rgba(0,200,150,0.4); transform: translateY(-1px); }
.btn-primary:disabled { opacity: 0.45; cursor: not-allowed; transform: none; box-shadow: none; }
.btn-ghost {
  background: transparent; color: var(--text-secondary);
  border: 1px solid var(--border-strong);
}
.btn-ghost:hover { background: var(--bg-hover); color: var(--text-primary); }
.btn-danger {
  background: var(--danger); color: #fff;
  box-shadow: 0 2px 12px var(--danger-glow);
}
.btn-danger:hover { background: var(--danger-dark); }
.btn-icon {
  width: 38px; height: 38px; padding: 0; border-radius: 50%;
  background: transparent; color: var(--text-secondary);
  border: none; display: flex; align-items: center; justify-content: center;
  font-size: 18px; transition: all var(--t-fast);
}
.btn-icon:hover { background: var(--bg-hover); color: var(--text-primary); }
.btn-full { width: 100%; }
 
/* ============================================================
   FORM ELEMENTS
   ============================================================ */
.form-group { display: flex; flex-direction: column; gap: 5px; }
.form-label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.6px;
  text-transform: uppercase; color: var(--text-secondary);
}
.form-input {
  width: 100%; padding: 11px 14px;
  background: var(--bg-input);
  border: 1px solid var(--border-strong);
  border-radius: var(--r-md);
  color: var(--text-primary);
  font-size: 14.5px; outline: none;
  transition: border-color var(--t-fast), box-shadow var(--t-fast);
  font-family: var(--font);
}
.form-input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-glow);
}
.form-input::placeholder { color: var(--text-muted); }
.form-input.error { border-color: var(--danger); box-shadow: 0 0 0 3px var(--danger-glow); }
.form-hint { font-size: 11px; color: var(--text-muted); }
 
.form-error {
  display: none; padding: 10px 14px;
  background: var(--danger-glow);
  border: 1px solid rgba(255,84,112,0.3);
  border-radius: var(--r-md);
  font-size: 13px; color: var(--danger);
  gap: 7px; align-items: flex-start;
}
.form-error.show { display: flex; }
.form-success {
  display: none; padding: 10px 14px;
  background: var(--accent-glow);
  border: 1px solid var(--accent-border);
  border-radius: var(--r-md);
  font-size: 13px; color: var(--accent);
}
.form-success.show { display: block; }
 
/* ============================================================
   AUTH SCREEN
   ============================================================ */
#screen-auth {
  position: fixed; inset: 0; z-index: 900;
  display: flex; align-items: center; justify-content: center;
  background: var(--bg-root);
  background-image:
    radial-gradient(ellipse 60% 60% at 20% 80%, rgba(0,200,150,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 80% 20%, rgba(0,150,200,0.04) 0%, transparent 60%);
  transition: opacity var(--t-slow), transform var(--t-slow);
}
#screen-auth.fade-out { opacity: 0; pointer-events: none; transform: scale(0.98); }
 
.auth-card {
  width: 100%; max-width: 420px; margin: 16px;
  background: var(--bg-panel);
  border: 1px solid var(--border-strong);
  border-radius: var(--r-xl);
  padding: 40px 36px 36px;
  box-shadow: var(--shadow-lg);
  animation: authSlideUp 0.5s cubic-bezier(0.22,1,0.36,1);
}
@keyframes authSlideUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}
 
.auth-brand {
  text-align: center; margin-bottom: 28px;
}
.auth-brand-logo {
  width: 60px; height: 60px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), #00a876);
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; margin: 0 auto 12px;
  box-shadow: var(--shadow-accent);
  position: relative;
}
.auth-brand-logo::after {
  content: '';
  position: absolute; inset: -3px;
  border-radius: 50%;
  border: 2px solid var(--accent-border);
  animation: logoPulse 2.5s ease-in-out infinite;
}
@keyframes logoPulse { 0%,100% { opacity: 0.6; transform: scale(1); } 50% { opacity: 0.2; transform: scale(1.12); } }
.auth-brand-name {
  font-size: 17px; font-weight: 700; color: var(--text-primary); letter-spacing: -0.3px;
}
.auth-brand-sub { font-size: 12px; color: var(--text-muted); margin-top: 3px; }
 
.auth-tabs {
  display: flex; gap: 4px;
  background: var(--bg-input);
  border-radius: var(--r-md);
  padding: 4px; margin-bottom: 24px;
}
.auth-tab {
  flex: 1; padding: 9px; border: none; background: transparent;
  color: var(--text-secondary); font-size: 13px; font-weight: 600;
  border-radius: calc(var(--r-md) - 2px);
  transition: all var(--t-fast); font-family: var(--font);
}
.auth-tab.active { background: var(--accent); color: #fff; }
 
.auth-form { display: flex; flex-direction: column; gap: 14px; }
 
.auth-divider {
  display: flex; align-items: center; gap: 10px;
  font-size: 11px; color: var(--text-muted); margin: 4px 0;
}
.auth-divider::before, .auth-divider::after {
  content: ''; flex: 1; height: 1px; background: var(--border);
}
 
/* ============================================================
   MAIN APP LAYOUT
   ============================================================ */
#app {
  display: flex; height: 100vh; overflow: hidden;
  opacity: 0; transition: opacity var(--t-slow);
}
#app.visible { opacity: 1; }
 
/* ============================================================
   SIDEBAR
   ============================================================ */
#sidebar {
  width: var(--sidebar-w); min-width: var(--sidebar-w);
  background: var(--bg-sidebar);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  height: 100vh; overflow: hidden;
  position: relative; z-index: 10;
}
 
.sidebar-top {
  height: var(--header-h);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 14px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  background: var(--bg-sidebar);
}
 
.sidebar-brand { display: flex; align-items: center; gap: 10px; }
.sidebar-logo-icon {
  width: 36px; height: 36px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), #00a876);
  display: flex; align-items: center; justify-content: center;
  font-size: 17px; flex-shrink: 0;
  box-shadow: 0 0 10px rgba(0,200,150,0.2);
}
.sidebar-logo-text {
  font-size: 15px; font-weight: 700; letter-spacing: -0.3px;
  background: linear-gradient(135deg, var(--accent), #4db8ff);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
 
.sidebar-top-actions { display: flex; align-items: center; gap: 2px; }
 
/* Sidebar Tabs */
.sidebar-tabs {
  display: flex; border-bottom: 1px solid var(--border);
  flex-shrink: 0; background: var(--bg-sidebar);
}
.sidebar-tab {
  flex: 1; padding: 12px 6px; background: transparent; border: none;
  color: var(--text-muted); font-size: 12px; font-weight: 600;
  letter-spacing: 0.4px; text-transform: uppercase;
  transition: all var(--t-fast); font-family: var(--font);
  border-bottom: 2px solid transparent; position: relative;
  display: flex; align-items: center; justify-content: center; gap: 5px;
}
.sidebar-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.sidebar-tab:hover:not(.active) { color: var(--text-secondary); background: var(--bg-hover); }
 
/* Search bar */
.sidebar-search {
  padding: 10px 12px; background: var(--bg-sidebar); flex-shrink: 0;
}
.search-bar {
  display: flex; align-items: center; gap: 8px;
  background: var(--bg-search);
  border: 1px solid var(--border);
  border-radius: var(--r-full);
  padding: 8px 12px;
  transition: border-color var(--t-fast);
}
.search-bar:focus-within { border-color: var(--accent-border); }
.search-bar-icon { font-size: 15px; color: var(--text-muted); flex-shrink: 0; }
.search-bar-input {
  flex: 1; background: transparent; border: none;
  color: var(--text-primary); font-size: 13.5px; outline: none;
  font-family: var(--font);
}
.search-bar-input::placeholder { color: var(--text-muted); }
 
/* My avatar */
.my-avatar-btn {
  width: 36px; height: 36px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 14px; cursor: pointer;
  border: none; transition: all var(--t-fast); flex-shrink: 0;
  position: relative;
}
.my-avatar-btn:hover { transform: scale(1.06); }
.my-avatar-online-dot {
  position: absolute; bottom: 1px; right: 1px;
  width: 10px; height: 10px; border-radius: 50%;
  background: var(--accent); border: 2px solid var(--bg-sidebar);
}
 
/* Conversation list */
.conv-list { flex: 1; overflow-y: auto; }
 
.conv-item {
  display: flex; align-items: center; gap: 12px;
  padding: 11px 14px; cursor: pointer;
  border-bottom: 1px solid transparent;
  transition: background var(--t-fast);
  position: relative;
}
.conv-item:hover { background: var(--bg-hover); }
.conv-item.active { background: var(--bg-active); border-left: 3px solid var(--accent); padding-left: 11px; }
.conv-item:not(:last-child) { border-bottom-color: var(--border); }
 
.conv-avatar {
  width: 50px; height: 50px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 19px; flex-shrink: 0;
  position: relative;
}
.conv-avatar-online {
  position: absolute; bottom: 2px; right: 2px;
  width: 12px; height: 12px; border-radius: 50%;
  background: var(--accent); border: 2.5px solid var(--bg-sidebar);
}
.conv-avatar-group {
  font-size: 22px; background: linear-gradient(135deg, #4a5568, #2d3748) !important;
}
 
.conv-content { flex: 1; min-width: 0; }
.conv-row1 { display: flex; align-items: baseline; justify-content: space-between; gap: 4px; margin-bottom: 3px; }
.conv-name {
  font-size: 14.5px; font-weight: 600; color: var(--text-primary);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.conv-time { font-size: 11px; color: var(--text-muted); flex-shrink: 0; }
.conv-row2 { display: flex; align-items: center; justify-content: space-between; gap: 4px; }
.conv-preview {
  font-size: 12.5px; color: var(--text-secondary);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  flex: 1;
}
.conv-badge {
  min-width: 20px; height: 20px; padding: 0 5px;
  background: var(--accent); color: #fff;
  border-radius: var(--r-full);
  display: flex; align-items: center; justify-content: center;
  font-size: 10.5px; font-weight: 700; flex-shrink: 0;
}
.conv-badge.muted { background: var(--text-muted); }
.conv-pinned { font-size: 11px; color: var(--text-muted); }
 
/* Empty states */
.empty-state {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 48px 20px; gap: 10px; text-align: center;
}
.empty-state-icon { font-size: 48px; margin-bottom: 4px; opacity: 0.7; }
.empty-state-title { font-size: 15px; font-weight: 600; color: var(--text-primary); }
.empty-state-desc { font-size: 12.5px; color: var(--text-secondary); max-width: 220px; line-height: 1.6; }
 
/* ============================================================
   CHAT PANEL
   ============================================================ */
#chat-panel {
  flex: 1; display: flex; flex-direction: column;
  height: 100vh; overflow: hidden;
  background: var(--bg-root);
  background-image:
    url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%2300c896' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  position: relative;
}
 
/* Chat Header */
#chat-header {
  height: var(--header-h);
  display: none; align-items: center; gap: 12px;
  padding: 0 16px;
  background: var(--bg-panel);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0; z-index: 5;
  box-shadow: var(--shadow-sm);
}
.chat-header-left { display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; cursor: pointer; }
.chat-header-avatar {
  width: 42px; height: 42px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 17px; flex-shrink: 0;
  position: relative;
}
.chat-header-avatar-online {
  position: absolute; bottom: 1px; right: 1px;
  width: 11px; height: 11px; border-radius: 50%;
  background: var(--accent); border: 2px solid var(--bg-panel);
}
.chat-header-name { font-size: 15.5px; font-weight: 700; color: var(--text-primary); }
.chat-header-status { font-size: 11.5px; color: var(--text-muted); }
.chat-header-status.online { color: var(--accent); }
.chat-header-actions { display: flex; align-items: center; gap: 2px; }
 
/* Search in chat */
.chat-search-bar {
  display: none; align-items: center; gap: 8px;
  padding: 8px 16px;
  background: var(--bg-panel);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.chat-search-bar.open { display: flex; }
.chat-search-input {
  flex: 1; background: var(--bg-input); border: 1px solid var(--border);
  border-radius: var(--r-full); padding: 7px 14px;
  color: var(--text-primary); font-size: 13.5px; outline: none;
  font-family: var(--font);
}
.chat-search-input:focus { border-color: var(--accent-border); }
.search-result-count { font-size: 12px; color: var(--text-muted); white-space: nowrap; }
 
/* Welcome */
#chat-welcome {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 14px; padding: 40px;
}
.welcome-glow {
  width: 90px; height: 90px; border-radius: 50%;
  background: radial-gradient(circle, var(--accent-glow), transparent 70%);
  display: flex; align-items: center; justify-content: center;
  font-size: 46px;
  animation: welcomeFloat 3s ease-in-out infinite;
}
@keyframes welcomeFloat {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-8px); }
}
.welcome-title { font-size: 24px; font-weight: 800; letter-spacing: -0.5px; }
.welcome-desc { font-size: 13.5px; color: var(--text-secondary); text-align: center; max-width: 300px; line-height: 1.7; }
.welcome-security-badge {
  display: flex; align-items: center; gap: 6px;
  background: var(--accent-glow); border: 1px solid var(--accent-border);
  border-radius: var(--r-full); padding: 6px 14px;
  font-size: 12px; color: var(--accent); margin-top: 4px;
}
 
/* ============================================================
   MESSAGES AREA
   ============================================================ */
#messages-area {
  flex: 1; overflow-y: auto;
  padding: 12px 6% 8px;
  display: none; flex-direction: column; gap: 1px;
  scroll-behavior: smooth;
}
 
/* Day separator */
.day-sep {
  display: flex; align-items: center; justify-content: center;
  margin: 10px 0 6px;
}
.day-sep-label {
  background: var(--bg-panel); color: var(--text-muted);
  font-size: 11.5px; font-weight: 600; letter-spacing: 0.3px;
  padding: 4px 14px; border-radius: var(--r-full);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-sm);
}
 
/* Encryption notice */
.enc-notice {
  display: flex; align-items: center; justify-content: center; gap: 6px;
  background: var(--accent-glow); border: 1px solid var(--accent-border);
  border-radius: var(--r-md); padding: 8px 16px;
  font-size: 11.5px; color: var(--accent);
  margin: 8px 0 4px; text-align: center;
}
 
/* Message wrapper */
.msg-wrap {
  display: flex; margin-bottom: 2px;
  animation: msgAppear 0.22s cubic-bezier(0.22,1,0.36,1);
}
@keyframes msgAppear {
  from { opacity: 0; transform: translateY(10px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
.msg-wrap.out { justify-content: flex-end; }
.msg-wrap.in  { justify-content: flex-start; }
.msg-wrap.group-start { margin-top: 8px; }
 
/* Avatar in group chats */
.msg-sender-avatar {
  width: 28px; height: 28px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 11px; flex-shrink: 0;
  align-self: flex-end; margin-right: 6px;
}
 
/* Bubble */
.msg-bubble {
  max-width: 68%; padding: 8px 12px 5px;
  border-radius: var(--r-lg);
  position: relative; word-break: break-word;
  cursor: pointer;
  transition: filter var(--t-fast);
}
.msg-bubble:hover { filter: brightness(1.06); }
.msg-wrap.out .msg-bubble {
  background: var(--bg-msg-out);
  border-bottom-right-radius: var(--r-xs);
}
.msg-wrap.in .msg-bubble {
  background: var(--bg-msg-in);
  border-bottom-left-radius: var(--r-xs);
  border: 1px solid var(--border);
}
 
/* Sender name (group) */
.msg-sender-name { font-size: 11.5px; font-weight: 700; margin-bottom: 3px; }
 
/* Reply preview */
.msg-reply-preview {
  background: rgba(0,0,0,0.2); border-left: 3px solid var(--accent);
  border-radius: var(--r-sm); padding: 5px 8px; margin-bottom: 6px;
  font-size: 11.5px; color: var(--text-secondary);
  cursor: pointer; transition: background var(--t-fast);
}
.msg-reply-preview:hover { background: rgba(0,0,0,0.3); }
.msg-reply-name { font-weight: 600; color: var(--accent); font-size: 11px; margin-bottom: 2px; }
.msg-reply-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
 
/* Image in message */
.msg-img {
  display: block; max-width: 240px; max-height: 300px;
  width: 100%; object-fit: cover;
  border-radius: var(--r-sm); margin-bottom: 4px;
  cursor: pointer; transition: opacity var(--t-fast);
}
.msg-img:hover { opacity: 0.9; }
.msg-img-loading {
  width: 240px; height: 180px; background: rgba(0,0,0,0.2);
  border-radius: var(--r-sm); display: flex; align-items: center; justify-content: center;
  margin-bottom: 4px;
}
 
/* Text */
.msg-text { font-size: 14px; color: var(--text-primary); line-height: 1.55; white-space: pre-wrap; }
.msg-text a { color: var(--text-link); text-decoration: underline; }
.msg-deleted-text { color: var(--text-muted); font-style: italic; font-size: 13px; }
.msg-edited-tag { font-size: 10px; color: var(--text-muted); margin-left: 4px; }
 
/* Meta */
.msg-meta {
  display: flex; align-items: center; justify-content: flex-end;
  gap: 4px; margin-top: 2px;
}
.msg-time { font-size: 10.5px; color: var(--text-muted); font-family: var(--font-mono); }
.msg-status { font-size: 12px; }
.msg-status.sent     { color: var(--text-muted); }
.msg-status.delivered{ color: var(--text-secondary); }
.msg-status.read     { color: #53bdeb; }
.msg-enc-icon { font-size: 10px; color: var(--accent); opacity: 0.6; }
 
/* Reactions bar */
.msg-reactions {
  display: flex; flex-wrap: wrap; gap: 4px; margin-top: 4px;
}
.reaction-chip {
  display: flex; align-items: center; gap: 3px;
  background: var(--bg-reaction); border: 1px solid var(--border);
  border-radius: var(--r-full); padding: 2px 7px;
  font-size: 12px; cursor: pointer;
  transition: all var(--t-fast);
}
.reaction-chip:hover { border-color: var(--accent-border); background: var(--accent-glow); }
.reaction-chip.mine  { border-color: var(--accent-border); background: var(--accent-glow); }
.reaction-count { font-size: 11px; color: var(--text-secondary); font-weight: 600; }
 
/* Context menu */
.msg-context-menu {
  position: absolute; z-index: 200;
  background: var(--bg-modal);
  border: 1px solid var(--border-strong);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-lg);
  overflow: hidden;
  min-width: 160px;
  animation: ctxAppear 0.15s ease;
}
@keyframes ctxAppear { from { opacity: 0; transform: scale(0.93); } to { opacity: 1; transform: scale(1); } }
.ctx-item {
  display: flex; align-items: center; gap: 9px;
  padding: 10px 14px; cursor: pointer;
  font-size: 13.5px; color: var(--text-primary);
  transition: background var(--t-fast);
}
.ctx-item:hover { background: var(--bg-hover); }
.ctx-item.danger { color: var(--danger); }
.ctx-item.danger:hover { background: var(--danger-glow); }
.ctx-icon { font-size: 15px; }
.ctx-sep { height: 1px; background: var(--border); margin: 3px 0; }
 
/* Emoji reaction picker (quick) */
.quick-emoji-bar {
  position: absolute; z-index: 201;
  background: var(--bg-modal); border: 1px solid var(--border-strong);
  border-radius: var(--r-full); padding: 6px 8px;
  display: flex; gap: 4px;
  box-shadow: var(--shadow-md);
  animation: ctxAppear 0.15s ease;
}
.quick-emoji {
  width: 34px; height: 34px; border-radius: 50%; border: none;
  background: transparent; font-size: 20px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all var(--t-fast);
}
.quick-emoji:hover { background: var(--bg-hover); transform: scale(1.18); }
 
/* ============================================================
   TYPING INDICATOR
   ============================================================ */
.typing-wrap {
  display: none; align-items: center; gap: 8px; margin: 4px 0;
  padding: 0 2px;
}
.typing-wrap.show { display: flex; }
.typing-bubble {
  background: var(--bg-msg-in); border: 1px solid var(--border);
  border-radius: var(--r-lg); border-bottom-left-radius: var(--r-xs);
  padding: 10px 14px; display: flex; gap: 4px; align-items: center;
}
.typing-dot {
  width: 6px; height: 6px; border-radius: 50%; background: var(--text-secondary);
  animation: typingBounce 1.4s infinite ease-in-out;
}
.typing-dot:nth-child(2) { animation-delay: 0.22s; }
.typing-dot:nth-child(3) { animation-delay: 0.44s; }
@keyframes typingBounce {
  0%,80%,100% { transform: translateY(0); opacity: 0.35; }
  40%          { transform: translateY(-5px); opacity: 1; }
}
.typing-label { font-size: 11px; color: var(--text-muted); }
 
/* ============================================================
   REPLY PREVIEW BAR (above input)
   ============================================================ */
#reply-preview {
  display: none; align-items: center; gap: 10px;
  padding: 8px 14px;
  background: var(--bg-panel);
  border-top: 1px solid var(--border);
  border-left: 3px solid var(--accent);
  flex-shrink: 0;
}
#reply-preview.show { display: flex; }
.reply-preview-content { flex: 1; min-width: 0; }
.reply-preview-name { font-size: 11.5px; font-weight: 700; color: var(--accent); }
.reply-preview-text { font-size: 12.5px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.reply-preview-close { background: none; border: none; color: var(--text-muted); font-size: 18px; cursor: pointer; padding: 2px; }
 
/* ============================================================
   MESSAGE INPUT AREA
   ============================================================ */
#input-area {
  display: none; align-items: flex-end; gap: 8px;
  padding: 10px 14px;
  background: var(--bg-panel);
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}
 
.input-attachments-btn {
  width: 44px; height: 44px; border-radius: 50%;
  background: transparent; border: none;
  color: var(--text-secondary); font-size: 22px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; cursor: pointer; transition: all var(--t-fast);
}
.input-attachments-btn:hover { color: var(--text-primary); background: var(--bg-hover); }
 
.input-box-wrap {
  flex: 1; min-width: 0;
  background: var(--bg-input); border: 1px solid var(--border);
  border-radius: var(--r-lg); padding: 10px 14px;
  transition: border-color var(--t-fast);
  position: relative;
}
.input-box-wrap:focus-within { border-color: var(--accent-border); }
 
#msg-textarea {
  width: 100%; background: transparent; border: none;
  color: var(--text-primary); font-size: 14.5px; outline: none;
  resize: none; max-height: 140px; line-height: 1.5;
  overflow-y: auto; font-family: var(--font);
  display: block;
}
#msg-textarea::placeholder { color: var(--text-muted); }
.input-char-count { font-size: 10px; color: var(--text-muted); text-align: right; margin-top: 2px; display: none; }
.input-char-count.warn { color: var(--warn); display: block; }
.input-char-count.danger { color: var(--danger); display: block; }
 
.input-send-btn {
  width: 46px; height: 46px; border-radius: 50%;
  background: var(--accent); border: none; color: #fff;
  font-size: 20px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all var(--t-fast);
  box-shadow: 0 2px 10px rgba(0,200,150,0.35);
}
.input-send-btn:hover { background: var(--accent-dark); transform: scale(1.06); box-shadow: 0 4px 16px rgba(0,200,150,0.45); }
.input-send-btn:active { transform: scale(0.93); }
.input-send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
 
/* Hidden file input */
#file-input { display: none; }
 
/* ============================================================
   EMOJI PICKER
   ============================================================ */
#emoji-picker {
  position: absolute; bottom: 78px; left: 14px; z-index: 100;
  background: var(--bg-modal);
  border: 1px solid var(--border-strong);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-lg);
  width: 320px; display: none;
  overflow: hidden;
}
#emoji-picker.open { display: block; }
 
.emoji-picker-header {
  display: flex; border-bottom: 1px solid var(--border); overflow-x: auto;
}
.emoji-cat-btn {
  flex-shrink: 0; padding: 8px 10px; background: none; border: none;
  font-size: 18px; cursor: pointer; border-bottom: 2px solid transparent;
  transition: all var(--t-fast);
}
.emoji-cat-btn:hover { background: var(--bg-hover); }
.emoji-cat-btn.active { border-bottom-color: var(--accent); }
.emoji-search-wrap { padding: 8px 10px; border-bottom: 1px solid var(--border); }
.emoji-search {
  width: 100%; background: var(--bg-input); border: 1px solid var(--border);
  border-radius: var(--r-sm); padding: 6px 10px;
  color: var(--text-primary); font-size: 13px; outline: none;
  font-family: var(--font);
}
.emoji-grid-wrap { padding: 6px 4px; max-height: 220px; overflow-y: auto; }
.emoji-grid { display: grid; grid-template-columns: repeat(8, 1fr); }
.emoji-btn-item {
  width: 36px; height: 36px; border: none; background: transparent;
  font-size: 20px; cursor: pointer; border-radius: var(--r-sm);
  display: flex; align-items: center; justify-content: center;
  transition: background var(--t-fast);
}
.emoji-btn-item:hover { background: var(--bg-hover); }
 
/* ============================================================
   PROFILE PANEL (right side)
   ============================================================ */
#profile-panel {
  width: 320px; background: var(--bg-panel);
  border-left: 1px solid var(--border);
  display: none; flex-direction: column;
  height: 100vh; overflow: hidden;
  animation: profileSlide var(--t-mid) ease;
  flex-shrink: 0;
}
#profile-panel.open { display: flex; }
@keyframes profileSlide { from { transform: translateX(100%); } to { transform: translateX(0); } }
 
.profile-panel-header {
  height: var(--header-h); display: flex; align-items: center; gap: 12px;
  padding: 0 14px; border-bottom: 1px solid var(--border); flex-shrink: 0;
}
.profile-panel-title { font-size: 16px; font-weight: 700; }
.profile-panel-body { flex: 1; overflow-y: auto; }
 
.profile-hero {
  background: linear-gradient(180deg, var(--bg-active), var(--bg-panel));
  padding: 28px; text-align: center;
  border-bottom: 1px solid var(--border);
}
.profile-hero-avatar {
  width: 90px; height: 90px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 800; font-size: 36px; margin: 0 auto 12px;
  box-shadow: 0 0 0 4px var(--accent-glow), var(--shadow-md);
}
.profile-hero-name { font-size: 20px; font-weight: 800; letter-spacing: -0.4px; }
.profile-hero-user { font-size: 13px; color: var(--text-secondary); margin-top: 3px; }
.profile-hero-status { margin-top: 8px; display: flex; align-items: center; justify-content: center; gap: 5px; font-size: 12.5px; }
.profile-online-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
 
.profile-section { padding: 14px; border-bottom: 1px solid var(--border); }
.profile-section-label { font-size: 10.5px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
.profile-info-row { display: flex; align-items: center; gap: 10px; padding: 6px 0; }
.profile-info-icon { font-size: 16px; width: 22px; text-align: center; color: var(--text-secondary); }
.profile-info-text { font-size: 13.5px; color: var(--text-primary); }
.profile-info-sub { font-size: 11px; color: var(--text-muted); }
.profile-action-btn {
  width: 100%; display: flex; align-items: center; gap: 10px;
  padding: 11px 14px; border: none; background: transparent;
  color: var(--text-primary); font-size: 13.5px; font-family: var(--font);
  cursor: pointer; border-radius: var(--r-md);
  transition: background var(--t-fast); margin-top: 4px;
}
.profile-action-btn:hover { background: var(--bg-hover); }
.profile-action-btn.danger { color: var(--danger); }
 
/* ============================================================
   MODALS
   ============================================================ */
.modal-overlay {
  position: fixed; inset: 0; z-index: 800;
  background: var(--bg-overlay);
  display: flex; align-items: center; justify-content: center;
  padding: 16px;
  animation: overlayIn 0.2s ease;
}
.modal-overlay.hidden { display: none; }
@keyframes overlayIn { from { opacity: 0; } to { opacity: 1; } }
 
.modal {
  width: 100%; max-width: 440px; max-height: 90vh;
  background: var(--bg-modal);
  border: 1px solid var(--border-strong);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-lg);
  overflow: hidden; overflow-y: auto;
  animation: modalIn 0.25s cubic-bezier(0.22,1,0.36,1);
}
@keyframes modalIn { from { opacity: 0; transform: translateY(16px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
.modal-sm { max-width: 360px; }
.modal-lg { max-width: 560px; }
 
.modal-header {
  display: flex; align-items: center; gap: 12px;
  padding: 20px 20px 16px;
  border-bottom: 1px solid var(--border);
}
.modal-icon { font-size: 24px; }
.modal-title-wrap { flex: 1; }
.modal-title { font-size: 17px; font-weight: 700; }
.modal-subtitle { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
.modal-close { background: none; border: none; color: var(--text-muted); font-size: 20px; cursor: pointer; transition: color var(--t-fast); }
.modal-close:hover { color: var(--text-primary); }
.modal-body { padding: 20px; display: flex; flex-direction: column; gap: 14px; }
.modal-footer { padding: 0 20px 20px; display: flex; gap: 10px; justify-content: flex-end; }
 
/* ============================================================
   TOAST NOTIFICATIONS
   ============================================================ */
#toast-root {
  position: fixed; bottom: 24px; right: 24px; z-index: 9999;
  display: flex; flex-direction: column; gap: 8px;
  pointer-events: none;
}
.toast {
  display: flex; align-items: center; gap: 10px;
  background: var(--bg-modal); color: var(--text-primary);
  border: 1px solid var(--border-strong);
  border-radius: var(--r-md); padding: 12px 16px;
  box-shadow: var(--shadow-lg); min-width: 240px; max-width: 340px;
  pointer-events: all;
  animation: toastIn 0.3s cubic-bezier(0.22,1,0.36,1);
}
@keyframes toastIn { from { opacity: 0; transform: translateX(40px); } to { opacity: 1; transform: translateX(0); } }
.toast.out { animation: toastOut 0.3s ease forwards; }
@keyframes toastOut { to { opacity: 0; transform: translateX(40px); } }
.toast-icon { font-size: 18px; flex-shrink: 0; }
.toast-content { flex: 1; min-width: 0; }
.toast-title { font-size: 13.5px; font-weight: 600; }
.toast-desc  { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
.toast.success { border-left: 3px solid var(--accent); }
.toast.error   { border-left: 3px solid var(--danger); }
.toast.warn    { border-left: 3px solid var(--warn); }
.toast.info    { border-left: 3px solid var(--info); }
 
/* ============================================================
   BAN SCREEN
   ============================================================ */
#ban-screen {
  position: fixed; inset: 0; z-index: 9999;
  background: #05090d;
  display: none; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 14px; padding: 40px;
  background-image: repeating-linear-gradient(
    -45deg,
    transparent,
    transparent 10px,
    rgba(255,84,112,0.03) 10px,
    rgba(255,84,112,0.03) 20px
  );
}
.ban-icon-wrap {
  width: 100px; height: 100px; border-radius: 50%;
  background: rgba(255,84,112,0.1);
  border: 2px solid rgba(255,84,112,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 52px;
  animation: banPulse 2s ease-in-out infinite;
  box-shadow: 0 0 40px rgba(255,84,112,0.2);
}
@keyframes banPulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.04); } }
.ban-title {
  font-size: 32px; font-weight: 800; color: var(--danger);
  letter-spacing: -1px; text-align: center;
}
.ban-code {
  font-family: var(--font-mono); font-size: 11px;
  color: var(--danger); background: rgba(255,84,112,0.1);
  border: 1px solid rgba(255,84,112,0.2);
  padding: 6px 16px; border-radius: var(--r-sm);
  letter-spacing: 1px;
}
.ban-reason { font-size: 15px; color: var(--text-secondary); text-align: center; max-width: 360px; line-height: 1.7; }
.ban-countdown { font-size: 13px; color: var(--text-muted); font-family: var(--font-mono); margin-top: 8px; }
.ban-timer-bar {
  width: 280px; height: 3px; background: rgba(255,255,255,0.08);
  border-radius: 2px; overflow: hidden; margin-top: 4px;
}
.ban-timer-progress {
  height: 100%; background: var(--danger);
  border-radius: 2px;
  transition: width 1s linear;
}
 
/* ============================================================
   IMAGE LIGHTBOX
   ============================================================ */
#lightbox {
  position: fixed; inset: 0; z-index: 8000;
  background: rgba(0,0,0,0.92);
  display: none; align-items: center; justify-content: center;
  cursor: zoom-out;
}
#lightbox.open { display: flex; }
#lightbox img {
  max-width: 90vw; max-height: 90vh;
  object-fit: contain; border-radius: var(--r-md);
  box-shadow: var(--shadow-lg);
  cursor: default;
}
.lightbox-close {
  position: absolute; top: 16px; right: 16px;
  background: rgba(0,0,0,0.5); border: none; color: #fff;
  width: 42px; height: 42px; border-radius: 50%; font-size: 20px;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: background var(--t-fast);
}
.lightbox-close:hover { background: rgba(0,0,0,0.8); }
 
/* ============================================================
   ADD CONTACT / GROUP MODALS — user result item
   ============================================================ */
.user-result {
  display: flex; align-items: center; gap: 12px;
  padding: 10px 12px; border-radius: var(--r-md);
  cursor: pointer; transition: background var(--t-fast);
}
.user-result:hover { background: var(--bg-hover); }
.user-result-avatar {
  width: 42px; height: 42px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 17px; flex-shrink: 0;
}
.user-result-name { font-size: 14.5px; font-weight: 600; }
.user-result-username { font-size: 12px; color: var(--text-secondary); }
.user-result-online { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); margin-left: auto; flex-shrink: 0; }
 
/* ============================================================
   SETTINGS MODAL
   ============================================================ */
.settings-section { border-bottom: 1px solid var(--border); padding-bottom: 14px; margin-bottom: 4px; }
.settings-section:last-child { border-bottom: none; }
.settings-section-title { font-size: 11px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
.settings-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 9px 0;
}
.settings-row-label { font-size: 13.5px; color: var(--text-primary); }
.settings-row-sub   { font-size: 11.5px; color: var(--text-secondary); margin-top: 1px; }
 
/* Toggle */
.toggle {
  width: 44px; height: 24px; border-radius: var(--r-full);
  background: var(--border-strong); position: relative;
  cursor: pointer; transition: background var(--t-fast); flex-shrink: 0;
}
.toggle.on { background: var(--accent); }
.toggle::after {
  content: ''; position: absolute;
  top: 3px; left: 3px;
  width: 18px; height: 18px; border-radius: 50%;
  background: #fff; transition: transform var(--t-fast);
  box-shadow: 0 1px 4px rgba(0,0,0,0.3);
}
.toggle.on::after { transform: translateX(20px); }
 
/* ============================================================
   NOTIFICATION PERMISSION BANNER
   ============================================================ */
#notif-banner {
  display: none; align-items: center; gap: 10px;
  background: var(--accent-glow); border-bottom: 1px solid var(--accent-border);
  padding: 9px 14px; flex-shrink: 0;
}
#notif-banner.show { display: flex; }
.notif-banner-text { flex: 1; font-size: 12.5px; color: var(--accent); }
.notif-banner-actions { display: flex; gap: 6px; }
 
/* ============================================================
   RESPONSIVE (mobile)
   ============================================================ */
@media (max-width: 768px) {
  :root { --sidebar-w: 100vw; }
  #sidebar { position: fixed; z-index: 100; height: 100%; transition: transform var(--t-mid); }
  #sidebar.hidden-mobile { transform: translateX(-100%); }
  #profile-panel { position: fixed; right: 0; z-index: 100; width: 100%; }
  #chat-panel { width: 100%; }
  .back-btn { display: flex !important; }
  #emoji-picker { width: 280px; }
}
 
/* ============================================================
   ENCRYPTION LOCK ANIMATION
   ============================================================ */
.enc-lock {
  display: inline-block;
  animation: lockBounce 0.4s cubic-bezier(0.22,1,0.36,1);
}
@keyframes lockBounce {
  0%  { transform: scale(0) rotate(-20deg); }
  70% { transform: scale(1.15) rotate(5deg); }
  100%{ transform: scale(1) rotate(0); }
}
 
/* ============================================================
   UPLOAD PROGRESS
   ============================================================ */
.upload-progress-wrap {
  position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  background: var(--border); border-radius: 2px; overflow: hidden;
}
.upload-progress-bar {
  height: 100%; background: var(--accent);
  transition: width 0.2s ease;
}
 
/* ============================================================
   NOTIFICATION DOT ON SIDEBAR ICON
   ============================================================ */
.notif-dot {
  position: absolute; top: 6px; right: 6px;
  width: 9px; height: 9px; border-radius: 50%;
  background: var(--danger); border: 2px solid var(--bg-sidebar);
}
 
/* ============================================================
   MOBILE BACK BUTTON
   ============================================================ */
.back-btn {
  display: none; align-items: center; justify-content: center;
  width: 36px; height: 36px; border-radius: 50%;
  background: transparent; border: none; color: var(--text-secondary);
  font-size: 20px; cursor: pointer; transition: all var(--t-fast);
}
.back-btn:hover { background: var(--bg-hover); color: var(--text-primary); }
 
/* ============================================================
   SELECTED MESSAGES MODE
   ============================================================ */
.msg-bubble.selected {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}
 
/* ============================================================
   STATUS BADGE
   ============================================================ */
.status-badge {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 10.5px; font-weight: 600;
  padding: 2px 8px; border-radius: var(--r-full);
}
.status-badge.online  { background: var(--accent-glow); color: var(--accent); }
.status-badge.offline { background: rgba(255,255,255,0.05); color: var(--text-muted); }
.status-badge.banned  { background: var(--danger-glow); color: var(--danger); }
 
/* ============================================================
   VERIFY BADGE
   ============================================================ */
.verify-icon { font-size: 12px; color: var(--accent); vertical-align: middle; }
 
/* ============================================================
   RATE LIMIT OVERLAY
   ============================================================ */
#rate-limit-overlay {
