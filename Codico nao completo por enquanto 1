async function startDMWith(otherUser) {
  closeModal('new-chat-modal');
 
  // Check if conversation already exists
  const existing = allConversations.find(c =>
    !c.isGroup && c.participantIds?.includes(otherUser.uid)
  );
  if (existing) {
    openConversation(existing);
    return;
  }
 
  // Create new conversation
  try {
    const participantIds = [currentUser.uid, otherUser.uid];
    const docRef = await db.collection('conversations').add({
      participantIds,
      isGroup: false,
      createdAt: firebase.firestore.FieldValue.serverTimestamp(),
      lastMessage: '',
      lastMessageAt: firebase.firestore.FieldValue.serverTimestamp(),
      unread: { [currentUser.uid]: 0, [otherUser.uid]: 0 },
      typing: { [currentUser.uid]: false, [otherUser.uid]: false },
      participantNames: {
        [currentUser.uid]: currentUserData.name,
        [otherUser.uid]: otherUser.name,
      },
    });
    // Add to local and open
    const conv = { id: docRef.id, participantIds, isGroup: false, otherUser, lastMessage: '', lastMessageAt: new Date() };
    openConversation(conv);
    showToast(`Conversa com ${otherUser.name} iniciada!`, '', 'success');
  } catch (e) {
    showToast('Erro ao criar conversa', e.message, 'error');
  }
}
 
