    .onSnapshot(async snap => {
      const raw  = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      const enriched = await Promise.all(raw.map(enrichConversation));
      allConversations = enriched.filter(Boolean);
      renderConvList(allConversations);
    }, err => {
      console.error('[Conversations] Listener error:', err);
      if (err.code === 'permission-denied') {
        // Firestore rules may need to be set up
        showToast('Permissão negada', 'Configure as regras do Firestore', 'warn', 8000);
      }
    });
}
 
async function enrichConversation(conv) {
  try {
    if (conv.isGroup) return conv;
    const otherId = conv.participantIds.find(id => id !== currentUser.uid);
    if (!otherId) return null;
    const uSnap = await db.collection('users').doc(otherId).get();
    if (!uSnap.exists) return null;
    return { ...conv, otherUser: uSnap.data() };
  } catch { return null; }
}
 
// ============================================================
// RENDER: CONVERSATION LIST
// ============================================================
function renderConvList(convs) {
  const list   = document.getElementById('conv-list');
  const search = document.getElementById('sidebar-search-input').value.toLowerCase();
  const tab    = currentSidebarTab;
 
  let filtered = convs.filter(c => {
    if (tab === 'groups') return c.isGroup;
    if (tab === 'chats')  return !c.isGroup;
    return true;
  });
 
  if (search) {
    filtered = filtered.filter(c => {
      const name = c.isGroup ? (c.groupName || '') : (c.otherUser?.name || '');
      return name.toLowerCase().includes(search) ||
             (c.otherUser?.username || '').toLowerCase().includes(search);
    });
  }
 
  if (!filtered.length) {
    list.innerHTML = `
      <div class="empty-state">
        <div class="empty-state-icon">${tab === 'groups' ? '👥' : '💬'}</div>
        <div class="empty-state-title">${search ? 'Sem resultados' : 'Nenhuma conversa'}</div>
        <div class="empty-state-desc">${search ? 'Tente outro termo' : 'Clique em ➕ para iniciar uma conversa'}</div>
      </div>`;
    return;
  }
 
  list.innerHTML = '';
  filtered.forEach(conv => {
    const el   = document.createElement('div');
    const name = conv.isGroup ? (conv.groupName || 'Grupo') : (conv.otherUser?.name || 'Desconhecido');
    const isOnline = !conv.isGroup && conv.otherUser?.online;
    const unread = (conv.unread || {})[currentUser.uid] || 0;
    const preview = conv.lastMessage || '';
    const timeStr = conv.lastMessageAt ? fmtConvTime(conv.lastMessageAt.toDate()) : '';
    const { bg, fg } = getAvatarPalette(name);
    const isActive = conv.id === activeConvId;
 
    el.className = `conv-item${isActive ? ' active' : ''}`;
    el.dataset.convId = conv.id;
    el.onclick = () => openConversation(conv);
 
    el.innerHTML = `
      <div class="conv-avatar ${conv.isGroup ? 'conv-avatar-group' : ''}" style="background:${bg};color:${fg};">
        ${conv.isGroup ? '👥' : getInitials(name)}
        ${isOnline && !conv.isGroup ? '<div class="conv-avatar-online"></div>' : ''}
      </div>
      <div class="conv-content">
        <div class="conv-row1">
          <span class="conv-name">${esc(name)}</span>
          <span class="conv-time">${esc(timeStr)}</span>
        </div>
        <div class="conv-row2">
          <span class="conv-preview">${esc(preview.slice(0, 50))}</span>
          ${unread ? `<span class="conv-badge">${unread > 99 ? '99+' : unread}</span>` : ''}
        </div>
      </div>`;
    list.appendChild(el);
  });
}
 
