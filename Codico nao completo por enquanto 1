    document.getElementById('chat-search-input').focus();
  } else {
    clearChatSearch();
  }
}
 
function clearChatSearch() {
  searchResults = [];
  searchCursor  = -1;
  document.getElementById('chat-search-input').value = '';
  document.getElementById('search-result-count').textContent = '';
  document.querySelectorAll('.msg-bubble.search-highlight').forEach(el => el.classList.remove('search-highlight'));
}
 
async function searchInChat(query) {
  if (!query.trim()) { clearChatSearch(); return; }
  const q = query.toLowerCase();
  searchResults = [];
  for (const msg of renderedMessages) {
    if (msg.deleted) continue;
    let text = decryptedCache.get(msg.id) || '';
    if (!text && msg.text && msg.encrypted) {
      text = await Crypto.decrypt(msg.text, activeConvId);
      decryptedCache.set(msg.id, text);
    } else if (msg.text && !msg.encrypted) {
      text = msg.text;
    }
    if (text.toLowerCase().includes(q)) {
      searchResults.push(msg.id);
    }
  }
  searchCursor = searchResults.length > 0 ? 0 : -1;
  document.getElementById('search-result-count').textContent =
    searchResults.length > 0 ? `${searchCursor + 1} / ${searchResults.length}` : 'Sem resultados';
  if (searchCursor >= 0) highlightSearchResult();
}
 
function navigateSearchResult(dir) {
  if (!searchResults.length) return;
  searchCursor = (searchCursor + dir + searchResults.length) % searchResults.length;
  document.getElementById('search-result-count').textContent = `${searchCursor + 1} / ${searchResults.length}`;
  highlightSearchResult();
}
 
function highlightSearchResult() {
  document.querySelectorAll('.msg-bubble.search-highlight').forEach(el => el.classList.remove('search-highlight'));
  const msgId = searchResults[searchCursor];
  const el    = document.querySelector(`[data-msg-id="${msgId}"] .msg-bubble`);
  if (el) {
    el.classList.add('search-highlight');
    el.style.outline = '2px solid var(--accent)';
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(() => { el.style.outline = ''; el.classList.remove('search-highlight'); }, 2500);
  }
}
 
