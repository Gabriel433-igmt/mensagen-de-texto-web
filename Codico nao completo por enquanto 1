// ============================================================
// MESSAGE CONTEXT MENU
// ============================================================
const QUICK_REACTIONS = ['👍','❤️','😂','😮','😢','🙏','🔥','😡'];
 
function showMsgContextMenu(e, msgId, isOut, convId, displayText) {
  e.preventDefault();
  e.stopPropagation();
  closeAllMenus();
 
  const isOwner = isOut === 'true' || isOut === true;
  const msg = renderedMessages.find(m => m.id === msgId);
  if (!msg) return;
 
  // Quick reaction bar
  const qbar = document.getElementById('quick-emoji-bar');
  qbar.innerHTML = QUICK_REACTIONS.map(em =>
    `<button class="quick-emoji" onclick="toggleReaction('${msgId}','${em}','${convId}');closeAllMenus();">${em}</button>`
  ).join('');
  qbar.classList.remove('hidden');
 
  // Position menu and reaction bar
  const vw = window.innerWidth, vh = window.innerHeight;
  let x = e.clientX, y = e.clientY;
 
  // Context menu items
  const menu = document.getElementById('msg-ctx-menu');
  menu.innerHTML = '';
 
  const items = [];
 
  // Reply (always)
  items.push({ icon: '↩️', label: 'Responder', fn: () => setReply(msg, displayText) });
 
  // Copy text
  if (displayText && !msg.deleted) {
    items.push({ icon: '📋', label: 'Copiar texto', fn: () => {
      navigator.clipboard.writeText(displayText).then(() => showToast('Copiado!', '', 'success'));
    }});
  }
 
  // Forward (stub)
  items.push({ icon: '↗️', label: 'Encaminhar', fn: () => showToast('Em breve', 'Encaminhar mensagem', 'info') });
 
  // Pin message
  items.push({ icon: '📌', label: 'Fixar mensagem', fn: () => pinMessage(msgId, displayText, convId) });
 
  items.push({ sep: true });
 
  // Delete own message
  if (isOwner && !msg.deleted) {
    items.push({ icon: '🗑️', label: 'Apagar mensagem', danger: true, fn: () => confirmDeleteMsg(msgId, convId) });
  }
 
  items.forEach(item => {
    if (item.sep) {
      const sep = document.createElement('div');
      sep.className = 'ctx-sep';
      menu.appendChild(sep);
      return;
    }
    const el = document.createElement('div');
    el.className = `ctx-item${item.danger ? ' danger' : ''}`;
    el.innerHTML = `<span class="ctx-icon">${item.icon}</span>${esc(item.label)}`;
    el.onclick = () => { item.fn(); closeAllMenus(); };
    menu.appendChild(el);
  });
 
  menu.classList.remove('hidden');
 
  // Position: keep in viewport
  const mw = 170, mh = items.length * 40 + 20;
  const qh = 50;
  if (x + mw > vw) x = vw - mw - 10;
  if (y + mh + qh > vh) y = vh - mh - qh - 10;
 
  qbar.style.left = x + 'px';
  qbar.style.top  = (y - qh - 4) + 'px';
  menu.style.left = x + 'px';
  menu.style.top  = y + 'px';
}
 
// ============================================================
// REACTIONS
// ============================================================
async function toggleReaction(msgId, emoji, convId) {
  if (!convId || !msgId) return;
  const msgRef = db.collection('conversations').doc(convId).collection('messages').doc(msgId);
  try {
    const snap = await msgRef.get();
    if (!snap.exists) return;
    const reactions = snap.data().reactions || {};
    const myReact   = reactions[currentUser.uid];
    if (myReact === emoji) {
      // Remove
      await msgRef.update({ [`reactions.${currentUser.uid}`]: firebase.firestore.FieldValue.delete() });
    } else {
      // Set
      await msgRef.update({ [`reactions.${currentUser.uid}`]: emoji });
    }
  } catch (e) {
    showToast('Erro ao reagir', '', 'error');
  }
}
 
