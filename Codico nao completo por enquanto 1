// AUTH: REGISTER
// ============================================================
async function handleRegister() {
  const name     = document.getElementById('reg-name').value.trim();
  const username = document.getElementById('reg-username').value.trim().toLowerCase();
  const email    = document.getElementById('reg-email').value.trim();
  const pass     = document.getElementById('reg-pass').value;
  const pass2    = document.getElementById('reg-pass2').value;
 
  // Validations
  if (!name || !username || !email || !pass || !pass2) {
    showAuthError('reg', 'Preencha todos os campos.'); return;
  }
  if (name.length < 2) { showAuthError('reg', 'Nome muito curto.'); return; }
  if (username.length < 3 || username.length > 20) {
    showAuthError('reg', 'Usuário deve ter 3–20 caracteres.'); return;
  }
  if (!/^[a-z0-9_]+$/.test(username)) {
    showAuthError('reg', 'Usuário: apenas letras minúsculas, números e _.'); return;
  }
  if (pass.length < 8) { showAuthError('reg', 'Senha mínimo de 8 caracteres.'); return; }
  if (pass !== pass2)  { showAuthError('reg', 'As senhas não coincidem.'); return; }
 
  // LUCAS CHECK
  if (isLucasDetected(name) || isLucasDetected(username)) {
    showAuthError('reg', '🚫 Nome proibido. Escolha outro nome de usuário.');
    setTimeout(() => triggerBan('Tentativa de registro com nome proibido (Lucas/abreviações).'), 1500);
    return;
  }
 
  setAuthLoading('reg-btn', 'reg-btn-text', true, 'Criar conta');
  clearAuthErrors();
 
  // Check username taken
  try {
    const snap = await db.collection('usernames').doc(username).get();
    if (snap.exists) {
      showAuthError('reg', 'Nome de usuário já está em uso.');
      setAuthLoading('reg-btn', 'reg-btn-text', false, 'Criar conta');
      return;
    }
  } catch (e) {
    showAuthError('reg', 'Erro ao verificar nome de usuário.');
    setAuthLoading('reg-btn', 'reg-btn-text', false, 'Criar conta');
    return;
  }
 
  // Create Firebase Auth user
  try {
    const cred = await auth.createUserWithEmailAndPassword(email, pass);
    const uid  = cred.user.uid;
 
    const batch = db.batch();
    const now   = firebase.firestore.FieldValue.serverTimestamp();
 
    batch.set(db.collection('users').doc(uid), {
      uid, name, username, email,
      about:    'Olá! Estou usando Mensagens de Texto na Web 👋',
      online:   true,
      banned:   false,
      createdAt: now,
      lastSeen:  now,
      settings: { soundEnabled: true, notifEnabled: false },
    });
    batch.set(db.collection('usernames').doc(username), { uid, name });
 
    await batch.commit();
    // Auth state change will handle the rest
  } catch (e) {
    const msgs = {
      'auth/email-already-in-use': 'E-mail já cadastrado.',
      'auth/invalid-email':        'E-mail inválido.',
      'auth/weak-password':        'Senha muito fraca.',
    };
    showAuthError('reg', msgs[e.code] || 'Erro ao criar conta.');
    setAuthLoading('reg-btn', 'reg-btn-text', false, 'Criar conta');
  }
}
 
