async function onUserLoggedIn() {
  try {
    const snap = await db.collection('users').doc(currentUser.uid).get();
    if (!snap.exists) {
      await auth.signOut();
      return;
    }
    currentUserData = snap.data();
 
    // Security checks
    if (currentUserData.banned) {
      triggerBan('Sua conta foi permanentemente suspensa por violação das regras.');
      return;
    }
    if (isLucasDetected(currentUserData.username) || isLucasDetected(currentUserData.name)) {
      await db.collection('users').doc(currentUser.uid).update({ banned: true });
      triggerBan('Nome proibido detectado. Conta suspensa automaticamente.');
      return;
    }
 
    // Set presence online
    await updatePresence(true);
 
    // Setup page unload presence
    window.addEventListener('beforeunload', () => updatePresence(false));
    document.addEventListener('visibilitychange', () => {
      updatePresence(!document.hidden);
    });
 
    // Load settings
    if (currentUserData.settings) {
      Object.assign(appSettings, currentUserData.settings);
    }
 
    showScreen('app');
    initAppUI();
    subscribeConversations();
    checkNotifPermission();
 
  } catch (e) {
    console.error('[Auth] onUserLoggedIn error:', e);
    showToast('Erro ao carregar conta', e.message, 'error');
  }
}
 
