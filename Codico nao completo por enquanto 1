async function handleFileSelect(input) {
  const file = input.files[0];
  if (!file) return;
  if (!activeConvId) { showToast('Abra uma conversa primeiro', '', 'warn'); return; }
 
  const maxMb = 5;
  if (file.size > maxMb * 1024 * 1024) {
    showToast('Arquivo muito grande', `Máximo ${maxMb}MB`, 'error');
    input.value = '';
    return;
  }
  if (!file.type.startsWith('image/')) {
    showToast('Tipo inválido', 'Apenas imagens são suportadas', 'error');
    input.value = '';
    return;
  }
 
  // Read as base64 (store in Firestore for simplicity)
  const reader = new FileReader();
  reader.onload = async (e) => {
    const b64 = e.target.result;
    await sendImageMessage(b64);
  };
  reader.readAsDataURL(file);
  input.value = '';
}
 
async function sendImageMessage(imageDataUrl) {
  if (!activeConvId) return;
  if (!msgRateLimiter.check()) {
    showToast('Muitas mensagens', '', 'warn');
    return;
  }
  try {
    const msgData = {
      text:      '',
      imageUrl:  imageDataUrl,
      encrypted: false,
      senderId:  currentUser.uid,
      senderName: currentUserData.name,
      timestamp: firebase.firestore.FieldValue.serverTimestamp(),
      read:      false, delivered: false, deleted: false,
      edited:    false, reactions: {},
    };
    await db.collection('conversations').doc(activeConvId)
      .collection('messages').add(msgData);
    await db.collection('conversations').doc(activeConvId).update({
      lastMessage:   '📷 Imagem',
      lastMessageAt: firebase.firestore.FieldValue.serverTimestamp(),
    });
  } catch (e) {
    showToast('Erro ao enviar imagem', e.message, 'error');
  }
}
 
