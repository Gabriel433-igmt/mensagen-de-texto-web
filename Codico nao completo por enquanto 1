// ============================================================
// OPEN CONVERSATION
// ============================================================
async function openConversation(conv) {
  // Cleanup previous listeners
  if (unsubMessages)   { unsubMessages(); unsubMessages = null; }
  if (unsubOtherUserPresence) { unsubOtherUserPresence(); unsubOtherUserPresence = null; }
  if (unsubTyping)     { unsubTyping(); unsubTyping = null; }
 
  activeConvId   = conv.id;
  activeConvData = conv;
  isGroupConv    = conv.isGroup || false;
  replyToMsg     = null;
  searchResults  = [];
  decryptedCache.clear();
 
  // Active state in list
  document.querySelectorAll('.conv-item').forEach(el => {
    el.classList.toggle('active', el.dataset.convId === conv.id);
  });
 
  // Show chat UI
  document.getElementById('chat-welcome').style.display     = 'none';
  document.getElementById('chat-header').style.display      = 'flex';
  document.getElementById('messages-area').style.display    = 'flex';
  document.getElementById('input-area').style.display       = 'flex';
 
  // Reset reply UI
  cancelReply();
 
  // Set header
  const name = isGroupConv ? (conv.groupName || 'Grupo') : (conv.otherUser?.name || '—');
  const { bg, fg } = getAvatarPalette(name);
  const hdrAvatar = document.getElementById('chat-hdr-avatar');
  hdrAvatar.style.background = bg;
  hdrAvatar.style.color = fg;
  hdrAvatar.innerHTML   = `${conv.isGroup ? '👥' : getInitials(name)}<div class="chat-header-avatar-online hidden" id="chat-hdr-online"></div>`;
 
  document.getElementById('chat-hdr-name').textContent = name;
  document.getElementById('chat-hdr-status').textContent = isGroupConv
    ? `${(conv.participantIds || []).length} membros`
    : 'Carregando...';
 
  // Reset unread
  if ((conv.unread || {})[currentUser.uid]) {
    db.collection('conversations').doc(conv.id).update({
      [`unread.${currentUser.uid}`]: 0
    }).catch(() => {});
  }
 
  // Mobile: hide sidebar
  if (window.innerWidth <= 768) {
    document.getElementById('sidebar').classList.add('hidden-mobile');
  }
 
  // Subscribe to messages
  subscribeMessages(conv.id);
 
  // Subscribe presence (DM only)
  if (!isGroupConv && conv.otherUser) {
    activeOtherUser = conv.otherUser;
    subscribeOtherUserPresence(conv.otherUser.uid);
  }
 
  // Subscribe typing
  subscribeTyping(conv.id);
 
  // Show pinned message if any
  loadPinnedMessage(conv.id);
 
  // Close profile panel if open
  closeProfilePanel();
 
  // Focus input
  setTimeout(() => document.getElementById('msg-textarea').focus(), 100);
}
 
// ============================================================
// SUBSCRIBE: OTHER USER PRESENCE
// ============================================================
function subscribeOtherUserPresence(uid) {
  if (unsubOtherUserPresence) unsubOtherUserPresence();
  unsubOtherUserPresence = db.collection('users').doc(uid).onSnapshot(snap => {
    if (!snap.exists) return;
    const data = snap.data();
    activeOtherUser = data;
    const statusEl = document.getElementById('chat-hdr-status');
    const onlineDot = document.getElementById('chat-hdr-online');
    if (data.online) {
      if (statusEl) { statusEl.textContent = 'online'; statusEl.className = 'chat-header-status online'; }
      if (onlineDot) onlineDot.classList.remove('hidden');
    } else {
      const ls = data.lastSeen?.toDate ? fmtLastSeen(data.lastSeen.toDate()) : 'offline';
      if (statusEl) { statusEl.textContent = ls; statusEl.className = 'chat-header-status'; }
      if (onlineDot) onlineDot.classList.add('hidden');
    }
  }, () => {});
}
 
// ============================================================
// SUBSCRIBE: TYPING INDICATORS
// ============================================================
function subscribeTyping(convId) {
  if (unsubTyping) unsubTyping();
  unsubTyping = db.collection('conversations').doc(convId).onSnapshot(snap => {
    if (!snap.exists) return;
    const data = snap.data();
    const typing = data.typing || {};
    const othersTyping = Object.entries(typing)
      .filter(([uid, val]) => uid !== currentUser.uid && val === true);
    const wrap  = document.getElementById('typing-wrap');
    const label = document.getElementById('typing-label');
    if (othersTyping.length > 0) {
      let typerName = '';
      if (isGroupConv) {
        typerName = data.participantNames?.[othersTyping[0][0]] || 'Alguém';
        label.textContent = `${typerName} está digitando...`;
      } else {
        label.textContent = 'digitando...';
      }
      wrap.style.display = 'flex';
    } else {
      wrap.style.display = 'none';
    }
  }, () => {});
}
 
// ============================================================
// SUBSCRIBE: MESSAGES
// ============================================================
function subscribeMessages(convId) {
  if (unsubMessages) unsubMessages();
 
  const area = document.getElementById('messages-area');
  area.innerHTML = '<div class="dots-loader" style="padding:40px;"><span></span><span></span><span></span></div>';
 
  unsubMessages = db.collection('conversations').doc(convId)
    .collection('messages')
    .orderBy('timestamp', 'asc')
    .onSnapshot(async snap => {
      const msgs = snap.docs.map(d => ({ id: d.id, ...d.data() }));
 
      // Detect new message for sound/notification
      const prevCount = renderedMessages.length;
      if (prevCount > 0 && msgs.length > prevCount) {
        const lastMsg = msgs[msgs.length - 1];
        if (lastMsg.senderId !== currentUser.uid) {
          playMessageSound();
          const name = isGroupConv
            ? (lastMsg.senderName || 'Alguém')
            : (activeOtherUser?.name || 'Mensagem');
          sendBrowserNotif(name, '📩 Nova mensagem');
        }
      }
 
      renderedMessages = msgs;
      await renderMessages(msgs, convId);
      markMessagesRead(msgs, convId);
    }, err => {
      console.error('[Messages] Listener error:', err);
      area.innerHTML = `<div class="empty-state"><div class="empty-state-icon">⚠️</div><div class="empty-state-title">Erro ao carregar</div><div class="empty-state-desc">${esc(err.message)}</div></div>`;
    });
}
 
// ============================================================
// RENDER: MESSAGES
// ============================================================
async function renderMessages(msgs, convId) {
  const area = document.getElementById('messages-area');
  const wasAtBottom = isNearBottom(area);
 
  area.innerHTML = '';
 
  // Encryption notice
  const encNotice = document.createElement('div');
  encNotice.className = 'enc-notice';
  encNotice.innerHTML = `<span class="enc-lock">🔐</span> As mensagens desta conversa são protegidas com criptografia AES-256-GCM`;
  area.appendChild(encNotice);
 
  let lastDay = null;
 
  for (const msg of msgs) {
    // Day separator
    if (msg.timestamp) {
      const day = fmtDayLabel(msg.timestamp.toDate());
      if (day !== lastDay) {
        lastDay = day;
        const sep = document.createElement('div');
        sep.className = 'day-sep';
        sep.innerHTML = `<span class="day-sep-label">${esc(day)}</span>`;
        area.appendChild(sep);
      }
    }
 
    const el = await buildMsgElement(msg, convId);
    area.appendChild(el);
  }
 
  // Typing wrap re-attach is managed separately; just scroll
  if (wasAtBottom) scrollToBottom();
  updateScrollBtn(area);
}
 
function isNearBottom(el) {
  return el.scrollHeight - el.scrollTop - el.clientHeight < 150;
}
 
function scrollToBottom() {
  const area = document.getElementById('messages-area');
  area.scrollTop = area.scrollHeight;
  const btn = document.getElementById('scroll-bottom-btn');
  btn.classList.remove('show');
}
 
function setupScrollObserver() {
  const area = document.getElementById('messages-area');
  area.addEventListener('scroll', () => updateScrollBtn(area));
}
 
function updateScrollBtn(area) {
  const btn = document.getElementById('scroll-bottom-btn');
  const far = area.scrollHeight - area.scrollTop - area.clientHeight > 200;
  btn.classList.toggle('show', far);
}
 
// ============================================================
// BUILD MESSAGE ELEMENT
// ============================================================
async function buildMsgElement(msg, convId) {
  const isOut    = msg.senderId === currentUser.uid;
  const wrap     = document.createElement('div');
  wrap.className = `msg-wrap ${isOut ? 'out' : 'in'}`;
  wrap.dataset.msgId = msg.id;
 
  // Decrypt text
  let displayText = '';
  if (msg.text && !msg.deleted) {
    if (decryptedCache.has(msg.id)) {
      displayText = decryptedCache.get(msg.id);
    } else {
      displayText = msg.encrypted
        ? await Crypto.decrypt(msg.text, convId)
        : msg.text;
      decryptedCache.set(msg.id, displayText);
    }
  }
 
  const timeStr = msg.timestamp ? fmtMsgTime(msg.timestamp.toDate()) : '';
  const statusIcon = isOut
    ? (msg.read ? '✓✓' : msg.delivered ? '✓✓' : '✓')
    : '';
  const statusClass = isOut
    ? (msg.read ? 'read' : msg.delivered ? 'delivered' : 'sent')
    : '';
 
  // Reactions HTML
  const reactions = msg.reactions || {};
  let reactionsHtml = '';
  const reactionEntries = Object.entries(reactions);
  if (reactionEntries.length > 0) {
    const groups = {};
    reactionEntries.forEach(([userId, emoji]) => {
      groups[emoji] = (groups[emoji] || []);
      groups[emoji].push(userId);
    });
    reactionsHtml = `<div class="msg-reactions">`;
    Object.entries(groups).forEach(([emoji, users]) => {
      const mine = users.includes(currentUser.uid);
      reactionsHtml += `<span class="reaction-chip${mine ? ' mine' : ''}" onclick="toggleReaction('${msg.id}','${emoji}','${convId}')" title="${users.length} reação${users.length > 1 ? 'ões' : ''}">
        ${emoji}<span class="reaction-count">${users.length}</span>
      </span>`;
    });
    reactionsHtml += `</div>`;
  }
 
  // Reply preview HTML
  let replyHtml = '';
  if (msg.replyTo && !msg.deleted) {
    const rName  = esc(msg.replyTo.senderName || 'Usuário');
    const rText  = esc((msg.replyTo.text || '').slice(0, 80));
    replyHtml = `<div class="msg-reply-preview" onclick="scrollToMsg('${msg.replyTo.id}')">
      <div class="msg-reply-name">${rName}</div>
      <div class="msg-reply-text">${rText}</div>
    </div>`;
  }
 
  // Sender name (group chats, incoming)
  let senderNameHtml = '';
  if (isGroupConv && !isOut && msg.senderName) {
    const { bg } = getAvatarPalette(msg.senderName);
    senderNameHtml = `<div class="msg-sender-name" style="color:${bg};">${esc(msg.senderName)}</div>`;
  }
 
  // Image HTML
  let imageHtml = '';
  if (msg.imageUrl && !msg.deleted) {
    imageHtml = `<img class="msg-img" src="${esc(msg.imageUrl)}" alt="Imagem" loading="lazy" onclick="openLightbox('${esc(msg.imageUrl)}')" onerror="this.parentElement.innerHTML='<div style=&quot;color:var(--text-muted);font-size:12px;&quot;>❌ Imagem indisponível</div>'">`;
  }
 
  // Deleted message
  let bodyHtml = '';
  if (msg.deleted) {
    bodyHtml = `<div class="msg-deleted-text">🚫 Mensagem apagada</div>`;
  } else {
    const editedTag = msg.edited ? '<span class="msg-edited-tag">(editado)</span>' : '';
    bodyHtml = `
      ${senderNameHtml}
      ${replyHtml}
      ${imageHtml}
      ${displayText ? `<div class="msg-text">${linkify(displayText)}${editedTag}</div>` : ''}`;
  }
 
  wrap.innerHTML = `
    <div class="msg-bubble" oncontextmenu="showMsgContextMenu(event,'${msg.id}','${isOut}','${convId}','${esc(displayText.slice(0,200)).replace(/'/g,"\\'")}')">
      ${bodyHtml}
      <div class="msg-reactions-container">${reactionsHtml}</div>
      <div class="msg-meta">
        ${msg.encrypted ? '<span class="msg-enc-icon">🔐</span>' : ''}
        <span class="msg-time">${timeStr}</span>
        ${isOut ? `<span class="msg-status ${statusClass}">${statusIcon}</span>` : ''}
      </div>
    </div>`;
 
  return wrap;
}
 
// ============================================================
// MARK MESSAGES AS READ
// ============================================================
async function markMessagesRead(msgs, convId) {
  if (!convId || !currentUser) return;
  const unread = msgs.filter(m => m.senderId !== currentUser.uid && !m.read && !m.deleted);
  if (!unread.length) return;
  const batch = db.batch();
  unread.forEach(m => {
    batch.update(
      db.collection('conversations').doc(convId).collection('messages').doc(m.id),
      { read: true, delivered: true }
    );
  });
  await batch.commit().catch(() => {});
}
 
// ============================================================
// SEND MESSAGE
// ============================================================
async function sendMessage() {
  const ta   = document.getElementById('msg-textarea');
  const text = ta.value.trim();
  if (!text && !uploadQueue.length) return;
  if (!activeConvId) return;
 
  // Rate limit check
  if (!msgRateLimiter.check()) {
    showRateLimitUI();
    showToast('Muitas mensagens', 'Aguarde antes de enviar novamente', 'warn');
    return;
  }
 
  // LUCAS CHECK on message content
  if (isLucasDetected(text)) {
    showToast('🚫 Conteúdo proibido', 'Sua mensagem contém termos banidos.', 'error');
    // Temporary input disable for 15s
    blockInputTemporarily(15);
    ta.value = '';
    ta.style.height = 'auto';
    return;
  }
 
  // Clear input immediately (optimistic)
  const msgText    = text;
  const msgReplyTo = replyToMsg ? { ...replyToMsg } : null;
  ta.value = '';
  ta.style.height = 'auto';
  cancelReply();
  clearTypingStatus();
  updateCharCount('');
 
  try {
    // Encrypt
    const encryptedText = msgText
      ? await Crypto.encrypt(msgText, activeConvId)
      : '';
 
    const msgData = {
      text:       encryptedText,
      encrypted:  true,
      senderId:   currentUser.uid,
      senderName: currentUserData.name,
      timestamp:  firebase.firestore.FieldValue.serverTimestamp(),
      read:       false,
      delivered:  false,
      deleted:    false,
      edited:     false,
      reactions:  {},
      ...(msgReplyTo ? { replyTo: msgReplyTo } : {}),
    };
 
    const msgRef = await db.collection('conversations').doc(activeConvId)
      .collection('messages').add(msgData);
 
    // Update conversation meta
    await db.collection('conversations').doc(activeConvId).update({
      lastMessage:    msgText.length > 60 ? msgText.slice(0, 60) + '…' : msgText,
      lastMessageAt:  firebase.firestore.FieldValue.serverTimestamp(),
      lastSenderId:   currentUser.uid,
      ...(activeConvData?.participantIds
        ? Object.fromEntries(
            activeConvData.participantIds
              .filter(id => id !== currentUser.uid)
              .map(id => [`unread.${id}`, firebase.firestore.FieldValue.increment(1)])
          )
        : {}),
    });
 
  } catch (e) {
    console.error('[Send] Error:', e);
    showToast('Erro ao enviar', e.message, 'error');
    ta.value = msgText; // Restore on error
  }
}
 
