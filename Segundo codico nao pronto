// CALLS
// ══════════════════════════════════════════════════
function startCall() {
  if (!SC.chat) return;
  const other = getOther(SC.chat);
  const ci    = colorIndex(other);

  const av = document.getElementById('call-av');
  av.textContent = other.charAt(0).toUpperCase();
  av.style.background = COLORS[ci];
  av.style.color = '#fff';

  document.getElementById('call-name').textContent = other;
  document.getElementById('call-status').textContent = 'Chamando...';
  document.getElementById('call-timer').classList.remove('show');
  document.getElementById('call-mute').classList.remove('on');
  document.getElementById('call-speaker').classList.add('on');

  document.getElementById('call-overlay').classList.add('open');
  SC.callActive = true;
  SC.callSecs   = 0;
  SC.callMuted  = false;

  // Simulate connect after 2.5s
  setTimeout(() => {
    if (!SC.callActive) return;
    document.getElementById('call-status').textContent = '● Conectado';
    document.getElementById('call-timer').classList.add('show');
    SC.callTimer = setInterval(() => {
      SC.callSecs++;
      const m = Math.floor(SC.callSecs/60).toString().padStart(2,'0');
      const s = (SC.callSecs%60).toString().padStart(2,'0');
      document.getElementById('call-timer').textContent = `${m}:${s}`;
    }, 1000);
  }, 2500);
}

function startVideoCall() {
  toast('📹 Videochamadas chegam em breve!', 'info');
}

function endCall() {
  clearInterval(SC.callTimer);
  SC.callActive = false;
  document.getElementById('call-overlay').classList.remove('open');
  if (SC.callSecs > 0) {
    const m = Math.floor(SC.callSecs/60);
    const s = SC.callSecs % 60;
    toast(`📞 Chamada encerrada · ${m}:${s.toString().padStart(2,'0')}`, 'info');
  }
}

function toggleCallMute() {
  SC.callMuted = !SC.callMuted;
  const btn = document.getElementById('call-mute');
  btn.classList.toggle('on', SC.callMuted);
  btn.textContent = SC.callMuted ? '🔇' : '🎤';
  toast(SC.callMuted ? '🔇 Mudo ativado' : '🎤 Mudo desativado', 'info');
}

function toggleCallSpeaker() {
  SC.callSpeaker = !SC.callSpeaker;
  const btn = document.getElementById('call-speaker');
  btn.classList.toggle('on', SC.callSpeaker);
  btn.textContent = SC.callSpeaker ? '🔊' : '🔈';
}

