// ── Firebase Wait Helper ───────────────────────────
function waitFB() {
  return new Promise(r => {
    if (window._fbReady) r();
    else document.addEventListener('firebase-ready', r, { once: true });
  });
}

// ── Firebase CRUD ──────────────────────────────────
async function fbSet(path, data) {
  await waitFB();
  const parts = path.split('/');
  const { doc, setDoc } = window._fbModules;
  await setDoc(doc(window._db, ...parts), data, { merge: true });
}

async function fbGet(path) {
  await waitFB();
  const parts = path.split('/');
  const { doc, getDoc } = window._fbModules;
  const snap = await getDoc(doc(window._db, ...parts));
  return snap.exists() ? { id: snap.id, ...snap.data() } : null;
}

async function fbAdd(coll, data) {
  await waitFB();
  const { collection, addDoc } = window._fbModules;
  return await addDoc(collection(window._db, coll), data);
}

async function fbDelete(path) {
  await waitFB();
  const parts = path.split('/');
  const { doc, deleteDoc } = window._fbModules;
  await deleteDoc(doc(window._db, ...parts));
}

async function fbListen(path, cb) {
  await waitFB();
  const parts = path.split('/');
  const { doc, onSnapshot } = window._fbModules;
  return onSnapshot(doc(window._db, ...parts), snap => {
    cb(snap.exists() ? { id: snap.id, ...snap.data() } : null);
  });
}

async function fbListenQuery(coll, constraints, cb) {
  await waitFB();
  const { collection, query, onSnapshot } = window._fbModules;
  const q = query(collection(window._db, coll), ...constraints);
  return onSnapshot(q, snap => {
    cb(snap.docs.map(d => ({ id: d.id, ...d.data() })));
  });
}

async function fbGetAll(coll) {
  await waitFB();
  const { collection, getDocs } = window._fbModules;
  const snap = await getDocs(collection(window._db, coll));
  return snap.docs.map(d => ({ id: d.id, ...d.data() }));
}

