// VALIDATION
// ══════════════════════════════════════════════════
function isBanned(text) {
  if (!text) return false;
  const t = text.toLowerCase();
  return BANNED.some(p => p.test(t));
}

function validateUsername(u) {
  if (!u) return 'Nome de usuário obrigatório.';
  if (u.length < 3) return 'Mínimo 3 caracteres.';
  if (u.length > 20) return 'Máximo 20 caracteres.';
  if (!/^[a-z0-9_]+$/i.test(u)) return 'Apenas letras, números e _.';
  if (isBanned(u)) return '❌ Nome de usuário não permitido.';
  return null;
}

function validateMessage(t) {
  if (!t || !t.trim()) return false;
  if (isBanned(t)) {
    toast('⚠️ Mensagem bloqueada — conteúdo não permitido.', 'error');
    return false;
  }
  return true;
}

function getPassStrength(pw) {
  let score = 0;
  if (pw.length >= 8)  score++;
  if (pw.length >= 12) score++;
  if (/[A-Z]/.test(pw)) score++;
  if (/[0-9]/.test(pw)) score++;
  if (/[^A-Za-z0-9]/.test(pw)) score++;
  return score;
}

function updatePassStrength(pw) {
  const wrap  = document.getElementById('pass-strength');
  const bar   = document.getElementById('pass-strength-bar');
  const label = document.getElementById('pass-strength-label');
  if (!pw) { wrap.style.display = 'none'; return; }
  wrap.style.display = 'block';
  const score = getPassStrength(pw);
  const pct   = [0,20,40,60,80,100][score];
  const cols  = ['','#ff3d71','#ff9500','#ffd60a','#00e5ff','#00ff88'];
  const labs  = ['','Muito fraca','Fraca','Razoável','Boa','Muito forte'];
  bar.style.width = pct + '%';
  bar.style.background = cols[score] || '#ff3d71';
  label.textContent = labs[score] || '';
  label.style.color = cols[score] || '#ff3d71';
}

