/* ── CSS Custom Properties ────────────────────────── */
:root {
  /* Core palette */
  --bg-deep:          #08090d;
  --bg-card:          #0f1117;
  --bg-panel:         #141720;
  --bg-input:         #191d28;
  --bg-hover:         #1c2132;
  --bg-active:        #1f2438;
  --bg-modal:         rgba(8,9,13,0.92);

  /* Accent colours */
  --accent-cyan:      #00e5ff;
  --accent-purple:    #7c3aed;
  --accent-green:     #00ff88;
  --accent-red:       #ff3d71;
  --accent-orange:    #ff9500;
  --accent-pink:      #ff2d78;
  --accent-yellow:    #ffd60a;
  --accent-teal:      #06b6d4;
  --accent-indigo:    #6366f1;

  /* Text */
  --text-primary:     #edf0f8;
  --text-secondary:   #7e8ba0;
  --text-muted:       #3d4557;
  --text-inverse:     #08090d;

  /* Borders */
  --border:           #1a2035;
  --border-active:    #273050;
  --border-focus:     var(--accent-cyan);

  /* Glows */
  --glow-cyan:    0 0 24px rgba(0,229,255,0.35);
  --glow-purple:  0 0 24px rgba(124,58,237,0.35);
  --glow-green:   0 0 24px rgba(0,255,136,0.35);
  --glow-red:     0 0 24px rgba(255,61,113,0.35);

  /* Shadows */
  --shadow-sm:    0 2px 8px rgba(0,0,0,0.4);
  --shadow-md:    0 8px 24px rgba(0,0,0,0.5);
  --shadow-lg:    0 20px 60px rgba(0,0,0,0.6);

  /* Radius */
  --r-xs:  4px;
  --r-sm:  8px;
  --r-md:  14px;
  --r-lg:  20px;
  --r-xl:  28px;
  --r-full: 9999px;

  /* Fonts */
  --font-ui:    'Syne', sans-serif;
  --font-mono:  'DM Mono', monospace;
  --font-serif: 'Fraunces', serif;

  /* Layout */
  --sidebar-w:  300px;
  --info-w:     270px;
  --header-h:   64px;
  --input-h:    72px;

  /* Easing */
  --ease-out:   cubic-bezier(0.0, 0.0, 0.2, 1);
  --ease-in:    cubic-bezier(0.4, 0.0, 1, 1);
  --ease-inout: cubic-bezier(0.4, 0.0, 0.2, 1);
  --spring:     cubic-bezier(0.34, 1.56, 0.64, 1);
  --t-fast:     0.15s;
  --t-normal:   0.25s;
  --t-slow:     0.4s;
}

/* ── Theme: Light ───────────────────────────────── */
.theme-light {
  --bg-deep:        #f0f2f8;
  --bg-card:        #ffffff;
  --bg-panel:       #f5f7fd;
  --bg-input:       #eef0f8;
  --bg-hover:       #e8eaf5;
  --bg-active:      #e0e3f0;
  --text-primary:   #1a1d2e;
  --text-secondary: #5a6480;
  --text-muted:     #9da8c4;
  --border:         #d8dce8;
  --border-active:  #b8bdd0;
}

/* ── Theme: Midnight ────────────────────────────── */
.theme-midnight {
  --bg-deep:   #000000;
  --bg-card:   #080808;
  --bg-panel:  #0d0d0d;
  --bg-input:  #111111;
  --bg-hover:  #151515;
  --accent-cyan: #00d4ff;
}

/* ── Theme: Forest ──────────────────────────────── */
.theme-forest {
  --bg-deep:      #0a1209;
  --bg-card:      #0f1c0e;
  --bg-panel:     #142013;
  --bg-input:     #192717;
  --bg-hover:     #1d2e1b;
  --accent-cyan:  #4ade80;
  --accent-purple:#86efac;
  --border:       #1a3018;
}

/* ── Theme: Ocean ───────────────────────────────── */
.theme-ocean {
  --bg-deep:      #050c18;
  --bg-card:      #091524;
  --bg-panel:     #0d1d30;
  --bg-input:     #10233a;
  --bg-hover:     #152b45;
  --accent-cyan:  #38bdf8;
  --accent-purple:#818cf8;
  --border:       #0e2236;
}

/* ── Reset & Base ───────────────────────────────── */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  -webkit-tap-highlight-color: transparent;
}

html {
  font-size: 16px;
  height: 100%;
  overflow: hidden;
}

body {
  font-family: var(--font-ui);
  background: var(--bg-deep);
  color: var(--text-primary);
  height: 100%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* Grain overlay */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 9999;
  opacity: 0.5;
}

/* ── Scrollbar ──────────────────────────────────── */
::-webkit-scrollbar              { width: 4px; height: 4px; }
::-webkit-scrollbar-track        { background: transparent; }
::-webkit-scrollbar-thumb        { background: var(--border-active); border-radius: 20px; }
::-webkit-scrollbar-thumb:hover  { background: var(--text-muted); }

/* ── Typography Scale ───────────────────────────── */
.text-xs   { font-size: 11px; }
.text-sm   { font-size: 13px; }
.text-base { font-size: 15px; }
.text-lg   { font-size: 18px; }
.text-xl   { font-size: 22px; }
.text-2xl  { font-size: 28px; }
.text-3xl  { font-size: 36px; }

.font-normal  { font-weight: 400; }
.font-medium  { font-weight: 500; }
.font-semi    { font-weight: 600; }
.font-bold    { font-weight: 700; }
.font-black   { font-weight: 800; }
.font-mono    { font-family: var(--font-mono); }
.font-serif   { font-family: var(--font-serif); }

/* ── Gradient Utilities ─────────────────────────── */
.grad-cyan-purple {
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
}
.grad-text {
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.grad-text-green {
  background: linear-gradient(135deg, var(--accent-green), var(--accent-teal));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ══════════════════════════════════════════════════
   KEYFRAME ANIMATIONS
   ══════════════════════════════════════════════════ */
@keyframes fadeIn       { from { opacity:0; transform:translateY(10px) } to { opacity:1; transform:translateY(0) } }
@keyframes fadeOut      { from { opacity:1 } to { opacity:0 } }
@keyframes slideInRight { from { opacity:0; transform:translateX(-18px) } to { opacity:1; transform:translateX(0) } }
@keyframes slideInLeft  { from { opacity:0; transform:translateX(18px) } to { opacity:1; transform:translateX(0) } }
@keyframes slideInUp    { from { opacity:0; transform:translateY(20px) } to { opacity:1; transform:translateY(0) } }
@keyframes slideInDown  { from { opacity:0; transform:translateY(-20px) } to { opacity:1; transform:translateY(0) } }
@keyframes scaleIn      { from { opacity:0; transform:scale(0.85) } to { opacity:1; transform:scale(1) } }
@keyframes msgIn        { from { opacity:0; transform:scale(0.88) translateY(8px) } to { opacity:1; transform:scale(1) translateY(0) } }
@keyframes float        { 0%,100%{ transform:translateY(0) } 50%{ transform:translateY(-9px) } }
@keyframes pulse        { 0%,100%{ opacity:1 } 50%{ opacity:0.4 } }
@keyframes spin         { to { transform:rotate(360deg) } }
@keyframes ping         { 0%{ transform:scale(1); opacity:.7 } 100%{ transform:scale(2.6); opacity:0 } }
@keyframes glow-pulse   { 0%,100%{ box-shadow:0 0 10px rgba(0,229,255,0.2) } 50%{ box-shadow:0 0 30px rgba(0,229,255,0.6) } }
@keyframes wave-bar     { 0%,100%{ height:3px } 50%{ height:18px } }
@keyframes ripple       { 0%{ transform:scale(0); opacity:1 } 100%{ transform:scale(4); opacity:0 } }
@keyframes call-pulse   { 0%{ box-shadow:0 0 0 0 rgba(0,255,136,.6) } 70%{ box-shadow:0 0 0 22px rgba(0,255,136,0) } 100%{ box-shadow:0 0 0 0 rgba(0,255,136,0) } }
@keyframes shake        { 0%,100%{ transform:translateX(0) } 20%{ transform:translateX(-9px) } 40%{ transform:translateX(9px) } 60%{ transform:translateX(-5px) } 80%{ transform:translateX(5px) } }
@keyframes typing-dot   { 0%,100%{ transform:translateY(0) } 50%{ transform:translateY(-7px) } }
@keyframes emoji-float  { 0%{ transform:translateY(0) scale(1); opacity:1 } 100%{ transform:translateY(-90px) scale(1.6); opacity:0 } }
@keyframes progress     { from{ width:0 } to{ width:100% } }
@keyframes border-glow  { 0%,100%{ border-color:rgba(0,229,255,0.3) } 50%{ border-color:rgba(0,229,255,0.8) } }
@keyframes confetti-drop{
  0%   { transform:translateY(-20px) rotate(0deg); opacity:1 }
  100% { transform:translateY(100vh) rotate(720deg); opacity:0 }
}
@keyframes status-blink { 0%,100%{ opacity:1 } 50%{ opacity:0.3 } }
@keyframes notification-in {
  0% { transform:translateX(110%); opacity:0 }
  60%{ transform:translateX(-5%); opacity:1 }
  100%{ transform:translateX(0); opacity:1 }
}
@keyframes notification-out {
  from{ transform:translateX(0); opacity:1 }
  to  { transform:translateX(110%); opacity:0 }
}
@keyframes highlight-flash {
  0%,100%{ background:transparent }
  50%    { background:rgba(0,229,255,0.12) }
}
@keyframes record-pulse {
  0%{ box-shadow:0 0 0 0 rgba(255,61,113,.7) }
  70%{ box-shadow:0 0 0 14px rgba(255,61,113,0) }
  100%{ box-shadow:0 0 0 0 rgba(255,61,113,0) }
}
@keyframes skeleton {
  0%{ background-position:200% 0 }
  100%{ background-position:-200% 0 }
}
@keyframes story-ring {
  0%   { stroke-dashoffset:220 }
  100% { stroke-dashoffset:0 }
}

/* ══════════════════════════════════════════════════
   AUTH SCREEN
   ══════════════════════════════════════════════════ */
#auth-screen {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-deep);
  z-index: 1000;
}

/* Animated background for auth */
#auth-screen::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 20% 30%, rgba(0,229,255,0.06) 0%, transparent 70%),
    radial-gradient(ellipse 50% 60% at 80% 70%, rgba(124,58,237,0.06) 0%, transparent 70%);
  pointer-events: none;
  animation: float 8s ease-in-out infinite;
}

.auth-wrap {
  display: flex;
  width: min(900px, 95vw);
  height: min(620px, 92vh);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-xl);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
  animation: scaleIn 0.4s var(--spring);
}

/* Left panel (branding) */
.auth-left {
  width: 380px;
  flex-shrink: 0;
  background: linear-gradient(145deg, #0a0d18 0%, #111827 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 40px;
  position: relative;
  overflow: hidden;
}

.auth-left::before {
  content: '';
  position: absolute;
  top: -40%;
  left: -40%;
  width: 180%;
  height: 180%;
  background: radial-gradient(circle at 50% 50%, rgba(0,229,255,0.07) 0%, transparent 65%);
  animation: float 6s ease-in-out infinite;
}

.auth-left-logo {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 36px;
  position: relative;
}

.auth-logo-icon {
  width: 56px;
  height: 56px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  box-shadow: var(--glow-cyan);
  animation: glow-pulse 3s ease-in-out infinite;
  position: relative;
}

.auth-logo-icon::after {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 18px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
  z-index: -1;
  filter: blur(8px);
  opacity: 0.5;
}

.auth-brand-name {
  font-size: 30px;
  font-weight: 800;
  letter-spacing: -1px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.auth-brand-tag {
  font-size: 12px;
  color: var(--text-muted);
  font-family: var(--font-mono);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-top: 4px;
}

.auth-features-list {
  list-style: none;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 14px;
  position: relative;
}

.auth-feature {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: var(--r-md);
  animation: slideInRight 0.5s var(--ease-out);
}

.auth-feature:nth-child(2) { animation-delay: 0.08s; }
.auth-feature:nth-child(3) { animation-delay: 0.16s; }
.auth-feature:nth-child(4) { animation-delay: 0.24s; }
.auth-feature:nth-child(5) { animation-delay: 0.32s; }

.auth-feature-icon {
  font-size: 22px;
  width: 36px;
  text-align: center;
}

.auth-feature-text { font-size: 13px; color: var(--text-secondary); }
.auth-feature-title { font-weight: 700; color: var(--text-primary); font-size: 13px; margin-bottom: 1px; }

/* Right panel (form) */
.auth-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 44px 40px;
  overflow-y: auto;
}

.auth-form-title   { font-size: 24px; font-weight: 700; margin-bottom: 6px; }
.auth-form-sub     { font-size: 13px; color: var(--text-secondary); margin-bottom: 28px; line-height: 1.5; }

.auth-tabs {
  display: flex;
  background: var(--bg-panel);
  border-radius: var(--r-md);
  padding: 4px;
  margin-bottom: 28px;
  gap: 4px;
}

.auth-tab {
  flex: 1;
  padding: 10px;
  border: none;
  border-radius: var(--r-sm);
  background: transparent;
  color: var(--text-muted);
  font-family: var(--font-ui);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--t-fast) var(--ease-out);
  letter-spacing: 0.2px;
}

.auth-tab.active {
  background: var(--bg-card);
  color: var(--accent-cyan);
  box-shadow: var(--shadow-sm);
}

/* ── Form Controls ──────────────────────────────── */
.field { margin-bottom: 18px; }

.field-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 11px;
  font-weight: 700;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.9px;
  margin-bottom: 8px;
}

.field-hint { font-size: 11px; color: var(--text-muted); font-weight: 400; text-transform: none; letter-spacing: 0; }

.field-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.field-input-wrap svg {
  position: absolute;
  left: 14px;
  color: var(--text-muted);
  pointer-events: none;
  transition: color var(--t-fast);
}

.field-input {
  width: 100%;
  padding: 13px 16px 13px 44px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  color: var(--text-primary);
  font-family: var(--font-ui);
  font-size: 14px;
  outline: none;
  transition: border-color var(--t-fast), box-shadow var(--t-fast);
}

.field-input:focus {
  border-color: var(--accent-cyan);
  box-shadow: 0 0 0 3px rgba(0,229,255,0.08);
}

.field-input:focus + svg,
.field-input-wrap:focus-within svg { color: var(--accent-cyan); }

.field-input::placeholder { color: var(--text-muted); }

.field-input.no-icon { padding-left: 16px; }

.field-error {
  font-size: 12px;
  color: var(--accent-red);
  margin-top: 6px;
  display: none;
  animation: fadeIn 0.2s ease;
}

.field-error.visible { display: block; }

/* Toggle password visibility */
.toggle-pass {
  position: absolute;
  right: 12px;
  background: none;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  padding: 4px;
  font-size: 16px;
  transition: color var(--t-fast);
  z-index: 1;
}

.toggle-pass:hover { color: var(--text-primary); }

/* ── Buttons ────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: none;
  border-radius: var(--r-md);
  font-family: var(--font-ui);
  font-weight: 700;
  cursor: pointer;
  transition: all var(--t-fast) var(--ease-out);
  position: relative;
  overflow: hidden;
  letter-spacing: 0.2px;
  user-select: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--accent-cyan), #009bbb);
  color: var(--text-inverse);
  padding: 14px 24px;
  font-size: 15px;
  width: 100%;
}

.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: var(--glow-cyan);
}

.btn-primary:active { transform: translateY(0); }
.btn-primary:disabled { opacity: 0.45; cursor: not-allowed; transform: none; box-shadow: none; }

.btn-secondary {
  background: var(--bg-panel);
  color: var(--text-secondary);
  border: 1px solid var(--border);
  padding: 12px 20px;
  font-size: 14px;
}

.btn-secondary:hover { background: var(--bg-hover); color: var(--text-primary); border-color: var(--border-active); }

.btn-danger {
  background: rgba(255,61,113,0.1);
  color: var(--accent-red);
  border: 1px solid rgba(255,61,113,0.25);
  padding: 12px 20px;
  font-size: 14px;
}

.btn-danger:hover { background: rgba(255,61,113,0.18); box-shadow: var(--glow-red); }

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  padding: 10px 16px;
  font-size: 13px;
}

.btn-ghost:hover { background: var(--bg-hover); color: var(--text-primary); }

.btn-icon {
  width: 38px;
  height: 38px;
  border-radius: var(--r-sm);
  background: var(--bg-panel);
  color: var(--text-secondary);
  padding: 0;
  border: 1px solid transparent;
}

.btn-icon:hover { background: var(--bg-hover); color: var(--text-primary); border-color: var(--border); }
.btn-icon.active { background: rgba(0,229,255,0.1); color: var(--accent-cyan); border-color: rgba(0,229,255,0.25); }
.btn-icon.danger:hover { background: rgba(255,61,113,0.1); color: var(--accent-red); border-color: rgba(255,61,113,0.25); }

/* Ripple on buttons */
.ripple {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.35);
  transform: scale(0);
  animation: ripple 0.55s var(--ease-out);
  pointer-events: none;
}

/* ── Security badge ─────────────────────────────── */
.security-badge {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  background: rgba(0,255,136,0.05);
  border: 1px solid rgba(0,255,136,0.2);
  border-radius: var(--r-md);
  margin-top: 18px;
}

.security-badge-dot {
  width: 9px;
  height: 9px;
  background: var(--accent-green);
  border-radius: 50%;
  animation: status-blink 2.5s infinite;
  flex-shrink: 0;
}

.security-badge-text { font-size: 12px; color: var(--accent-green); font-weight: 600; }
.security-badge-sub  { font-size: 11px; color: var(--text-muted); }

/* ══════════════════════════════════════════════════
   MAIN APP LAYOUT
   ══════════════════════════════════════════════════ */
#app {
  display: none;
  width: 100vw;
  height: 100vh;
  flex-direction: row;
  overflow: hidden;
}

#app.active { display: flex; animation: fadeIn 0.35s ease; }

/* ══════════════════════════════════════════════════
   SIDEBAR
   ══════════════════════════════════════════════════ */
.sidebar {
  width: var(--sidebar-w);
  min-width: var(--sidebar-w);
  height: 100vh;
  background: var(--bg-card);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 20;
  transition: transform var(--t-normal) var(--ease-out);
}

/* ── Sidebar header ─────────────────────────────── */
.sidebar-header {
  padding: 18px 16px 14px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.sidebar-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
}

.brand-icon {
  width: 34px;
  height: 34px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  box-shadow: var(--glow-cyan);
  animation: glow-pulse 4s ease-in-out infinite;
}

.brand-name {
  font-size: 17px;
  font-weight: 800;
  letter-spacing: -0.3px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.brand-version {
  font-size: 9px;
  color: var(--text-muted);
  font-family: var(--font-mono);
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1px 5px;
  margin-top: 2px;
  letter-spacing: 0.5px;
}

.sidebar-header-actions {
  display: flex;
  gap: 6px;
  align-items: center;
}

/* ── Search ─────────────────────────────────────── */
.search-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 10px 14px;
  transition: border-color var(--t-fast), box-shadow var(--t-fast);
}

.search-wrap:focus-within {
  border-color: var(--accent-cyan);
  box-shadow: 0 0 0 3px rgba(0,229,255,0.07);
}

.search-wrap svg { color: var(--text-muted); flex-shrink: 0; transition: color var(--t-fast); }
.search-wrap:focus-within svg { color: var(--accent-cyan); }

.search-input {
  flex: 1;
  border: none;
  background: transparent;
  color: var(--text-primary);
  font-family: var(--font-ui);
  font-size: 13px;
  outline: none;
}

.search-input::placeholder { color: var(--text-muted); }

/* ── My profile strip ───────────────────────────── */
.my-profile-strip {
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  background: linear-gradient(135deg, rgba(0,229,255,0.03), rgba(124,58,237,0.03));
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  transition: background var(--t-fast);
  flex-shrink: 0;
}

.my-profile-strip:hover { background: linear-gradient(135deg, rgba(0,229,255,0.06), rgba(124,58,237,0.06)); }

.my-status-dot {
  position: absolute;
  bottom: 1px;
  right: 1px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  border: 2px solid var(--bg-card);
}

.status-online  .my-status-dot { background: var(--accent-green); }
.status-away    .my-status-dot { background: var(--accent-orange); }
.status-busy    .my-status-dot { background: var(--accent-red); }
.status-offline .my-status-dot { background: var(--text-muted); }

.my-profile-info { flex: 1; min-width: 0; }
.my-profile-name { font-size: 13px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.my-profile-status-text { font-size: 11px; color: var(--accent-green); margin-top: 2px; display: flex; align-items: center; gap: 5px; }
.my-profile-status-text::before { content: ''; display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--accent-green); animation: status-blink 2s infinite; }

/* ── Stories/Status Row ─────────────────────────── */
.stories-row {
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.stories-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  color: var(--text-muted);
  margin-bottom: 10px;
}

.stories-scroll {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  padding-bottom: 4px;
}

.stories-scroll::-webkit-scrollbar { height: 2px; }

.story-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  cursor: pointer;
  flex-shrink: 0;
}

.story-ring {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  padding: 2px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
  position: relative;
}

.story-ring.seen {
  background: var(--border);
}

.story-ring-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2px;
}

.story-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 700;
  color: #fff;
}

.story-name {
  font-size: 10px;
  color: var(--text-secondary);
  white-space: nowrap;
  max-width: 52px;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: center;
}

.story-add {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--bg-panel);
  border: 2px dashed var(--border-active);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  cursor: pointer;
  transition: all var(--t-fast);
}

.story-add:hover { border-color: var(--accent-cyan); background: rgba(0,229,255,0.05); }

/* ── Nav Tabs ───────────────────────────────────── */
.nav-tabs {
  display: flex;
  padding: 10px 10px 0;
  gap: 2px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.nav-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 9px 6px 10px;
  border: none;
  background: transparent;
  color: var(--text-muted);
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all var(--t-fast);
  position: relative;
}

.nav-tab:hover:not(.active) { color: var(--text-secondary); }

.nav-tab.active {
  color: var(--accent-cyan);
  border-bottom-color: var(--accent-cyan);
}

.nav-tab-badge {
  position: absolute;
  top: 6px;
  right: 50%;
  transform: translateX(12px);
  background: var(--accent-red);
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  border-radius: var(--r-full);
  padding: 1px 5px;
  min-width: 16px;
  text-align: center;
  animation: scaleIn 0.2s var(--spring);
}

/* ── Conversation List ──────────────────────────── */
.conv-list {
  flex: 1;
  overflow-y: auto;
  padding: 6px;
}

.conv-section-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.4px;
  color: var(--text-muted);
  padding: 10px 10px 6px;
}

.conv-item {
  display: flex;
  align-items: center;
  gap: 11px;
  padding: 10px 10px;
  border-radius: var(--r-md);
  cursor: pointer;
  transition: background var(--t-fast);
  position: relative;
  animation: slideInRight 0.28s var(--ease-out);
}

.conv-item:hover { background: var(--bg-hover); }

.conv-item.active {
  background: rgba(0,229,255,0.07);
}

.conv-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 25%;
  height: 50%;
  width: 3px;
  background: var(--accent-cyan);
  border-radius: 0 3px 3px 0;
}

.conv-item.pinned::after {
  content: '📌';
  position: absolute;
  right: 10px;
  top: 10px;
  font-size: 10px;
}

.conv-info { flex: 1; min-width: 0; }

.conv-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 3px;
}

.conv-name {
  font-size: 13px;
  font-weight: 700;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

.conv-time {
  font-size: 10px;
  color: var(--text-muted);
  font-family: var(--font-mono);
  flex-shrink: 0;
  margin-left: 6px;
}

.conv-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.conv-preview {
  font-size: 12px;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

.conv-preview.unread { color: var(--text-primary); font-weight: 600; }

.conv-badge {
  flex-shrink: 0;
  background: var(--accent-cyan);
  color: var(--text-inverse);
  font-size: 10px;
  font-weight: 700;
  border-radius: var(--r-full);
  padding: 2px 7px;
  min-width: 20px;
  text-align: center;
  margin-left: 6px;
  animation: scaleIn 0.2s var(--spring);
}

.conv-badge.muted { background: var(--text-muted); }

/* ── Avatar System ──────────────────────────────── */
.av {
  position: relative;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  text-transform: uppercase;
  color: #fff;
  flex-shrink: 0;
}

.av-xs  { width: 28px; height: 28px; font-size: 11px; }
.av-sm  { width: 36px; height: 36px; font-size: 14px; }
.av-md  { width: 44px; height: 44px; font-size: 16px; }
.av-lg  { width: 60px; height: 60px; font-size: 22px; }
.av-xl  { width: 80px; height: 80px; font-size: 30px; }

.av-online::after, .av-away::after, .av-busy::after, .av-offline::after {
  content: '';
  position: absolute;
  bottom: 1px;
  right: 1px;
  border-radius: 50%;
  border: 2px solid var(--bg-card);
  width: 11px;
  height: 11px;
}

.av-online::after  { background: var(--accent-green); }
.av-away::after    { background: var(--accent-orange); }
.av-busy::after    { background: var(--accent-red); }
.av-offline::after { background: var(--text-muted); }

.av-sm.av-online::after, .av-sm.av-away::after,
.av-sm.av-busy::after, .av-sm.av-offline::after { width: 9px; height: 9px; }

/* ── Empty State ────────────────────────────────── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  gap: 12px;
  text-align: center;
}

.empty-icon { font-size: 44px; animation: float 3s ease-in-out infinite; }
.empty-title { font-size: 15px; font-weight: 700; color: var(--text-primary); }
.empty-sub   { font-size: 13px; color: var(--text-muted); line-height: 1.5; max-width: 220px; }

/* ── Skeleton Loader ────────────────────────────── */
.skeleton {
  background: linear-gradient(
    90deg,
    var(--bg-panel) 25%,
    var(--bg-hover) 37%,
    var(--bg-panel) 63%
  );
  background-size: 400% 100%;
  animation: skeleton 1.4s ease-in-out infinite;
  border-radius: var(--r-sm);
}

/* ══════════════════════════════════════════════════
   CHAT AREA
   ══════════════════════════════════════════════════ */
.chat-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg-deep);
  position: relative;
}

/* Grid bg */
.chat-area::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,229,255,0.015) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,229,255,0.015) 1px, transparent 1px);
  background-size: 44px 44px;
  pointer-events: none;
  z-index: 0;
}

/* ── Chat Header ────────────────────────────────── */
.chat-hdr {
  padding: 0 20px;
  height: var(--header-h);
  background: var(--bg-card);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 14px;
  z-index: 10;
  position: relative;
  flex-shrink: 0;
}

.chat-hdr-info { flex: 1; min-width: 0; }
.chat-hdr-name { font-size: 15px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.chat-hdr-meta {
  font-size: 12px;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 2px;
}

.hdr-status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--accent-green);
  animation: status-blink 2.5s infinite;
}

.chat-hdr-actions { display: flex; gap: 6px; align-items: center; }

.hdr-btn {
  width: 38px;
  height: 38px;
  border: none;
  background: var(--bg-panel);
  border-radius: var(--r-sm);
  color: var(--text-secondary);
  cursor: pointer;
  transition: all var(--t-fast);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  position: relative;
}

.hdr-btn:hover { background: var(--bg-hover); color: var(--text-primary); }
.hdr-btn.call:hover   { background: rgba(0,255,136,0.1); color: var(--accent-green); }
.hdr-btn.video:hover  { background: rgba(124,58,237,0.1); color: var(--accent-purple); }
.hdr-btn.search:hover { background: rgba(0,229,255,0.1); color: var(--accent-cyan); }
.hdr-btn.active       { background: rgba(0,229,255,0.12); color: var(--accent-cyan); }

.e2e-chip {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 5px 10px;
  background: rgba(0,255,136,0.06);
  border: 1px solid rgba(0,255,136,0.18);
  border-radius: var(--r-full);
  font-size: 10px;
  font-weight: 700;
  color: var(--accent-green);
  letter-spacing: 0.3px;
  white-space: nowrap;
}

.e2e-chip svg { flex-shrink: 0; }

/* ── In-chat search bar ─────────────────────────── */
.chat-search-bar {
  background: var(--bg-card);
  border-bottom: 1px solid var(--border);
  padding: 10px 20px;
  display: none;
  align-items: center;
  gap: 12px;
  animation: slideInDown 0.2s ease;
}

.chat-search-bar.visible { display: flex; }

.chat-search-input {
  flex: 1;
  border: 1px solid var(--border);
  background: var(--bg-input);
  border-radius: var(--r-md);
  padding: 9px 14px;
  color: var(--text-primary);
  font-family: var(--font-ui);
  font-size: 13px;
  outline: none;
  transition: border-color var(--t-fast);
}

.chat-search-input:focus { border-color: var(--accent-cyan); }
.chat-search-count { font-size: 12px; color: var(--text-muted); font-family: var(--font-mono); white-space: nowrap; }

/* ── Messages Area ──────────────────────────────── */
.msgs {
  flex: 1;
  overflow-y: auto;
  padding: 20px 20px 12px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  position: relative;
  z-index: 1;
}

/* Scroll-to-bottom button */
.scroll-bottom-btn {
  position: absolute;
  bottom: 90px;
  right: 24px;
  width: 40px;
  height: 40px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 50%;
  cursor: pointer;
  display: none;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  box-shadow: var(--shadow-md);
  z-index: 10;
  transition: all var(--t-fast);
  animation: scaleIn 0.2s var(--spring);
}

.scroll-bottom-btn.visible { display: flex; }
.scroll-bottom-btn:hover { background: var(--bg-hover); transform: scale(1.08); }
.scroll-bottom-btn .unread-count {
  position: absolute;
  top: -6px;
  right: -6px;
  background: var(--accent-cyan);
  color: var(--text-inverse);
  font-size: 9px;
  font-weight: 700;
  border-radius: var(--r-full);
  padding: 2px 5px;
  min-width: 18px;
  text-align: center;
}

/* ── Date separator ─────────────────────────────── */
.date-sep {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 14px 0;
}

.date-sep-line { flex: 1; height: 1px; background: var(--border); }

.date-sep-label {
  font-size: 10px;
  color: var(--text-muted);
  font-family: var(--font-mono);
  padding: 4px 12px;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--r-full);
  white-space: nowrap;
}

/* ── Message Row ────────────────────────────────── */
.msg-row {
  display: flex;
  gap: 9px;
  margin-bottom: 2px;
}

.msg-row.mine { flex-direction: row-reverse; }

.msg-row .av { align-self: flex-end; }

.msg-group {
  display: flex;
  flex-direction: column;
  max-width: 62%;
  gap: 2px;
}

.msg-row.mine .msg-group { align-items: flex-end; }

.msg-sender-label {
  font-size: 11px;
  font-weight: 700;
  color: var(--text-muted);
  margin-bottom: 4px;
  padding-left: 12px;
}

/* ── Bubble ─────────────────────────────────────── */
.bubble {
  padding: 10px 14px;
  border-radius: 18px;
  font-size: 14px;
  line-height: 1.55;
  word-break: break-word;
  max-width: 100%;
  position: relative;
  transition: filter var(--t-fast);
}

.bubble:hover { filter: brightness(1.05); }

/* Theirs */
.msg-row:not(.mine) .bubble {
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-bottom-left-radius: 5px;
  color: var(--text-primary);
}

/* Mine */
.msg-row.mine .bubble {
  background: linear-gradient(135deg, var(--accent-cyan) 0%, #009bbb 100%);
  color: var(--text-inverse);
  border-bottom-right-radius: 5px;
  font-weight: 500;
}

/* Emoji only */
.bubble.only-emoji {
  background: transparent !important;
  border: none !important;
  font-size: 40px;
  padding: 4px 6px;
  line-height: 1.1;
}

/* Highlighted (search result) */
.bubble.highlighted { animation: highlight-flash 1.5s ease; }

/* Reply quote inside bubble */
.bubble-reply {
  padding: 7px 10px;
  border-left: 3px solid;
  border-radius: 0 6px 6px 0;
  margin-bottom: 7px;
  font-size: 12px;
  opacity: 0.8;
}

.msg-row:not(.mine) .bubble-reply {
  background: rgba(0,0,0,0.12);
  border-color: var(--accent-cyan);
  color: var(--text-secondary);
}

.msg-row.mine .bubble-reply {
  background: rgba(0,0,0,0.15);
  border-color: rgba(0,0,0,0.4);
  color: rgba(0,0,0,0.7);
}

.bubble-reply-sender { font-weight: 700; margin-bottom: 2px; }

/* Link preview */
.link-preview {
  margin-top: 8px;
  border-radius: var(--r-sm);
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.15);
}

.link-preview-img { width: 100%; height: 80px; object-fit: cover; display: block; }
.link-preview-info { padding: 8px 10px; background: rgba(0,0,0,0.2); }
.link-preview-domain { font-size: 10px; opacity: 0.7; text-transform: uppercase; margin-bottom: 2px; }
.link-preview-title  { font-size: 12px; font-weight: 600; }

/* ── Message footer ─────────────────────────────── */
.msg-footer {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 0 4px;
  font-size: 10px;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

.msg-row.mine .msg-footer { color: rgba(0,0,0,0.4); }

.tick { font-size: 12px; }
.tick.sent     { color: var(--text-muted); }
.tick.delivered{ color: var(--text-secondary); }
.tick.read     { color: var(--accent-cyan); }

.msg-encrypted-badge {
  font-size: 10px;
  opacity: 0.55;
  display: inline-flex;
  align-items: center;
  gap: 2px;
}

/* ── Message Reactions ──────────────────────────── */
.msg-reactions {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
  margin-top: 4px;
}

.react-pill {
  display: flex;
  align-items: center;
  gap: 3px;
  padding: 3px 8px;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--r-full);
  font-size: 13px;
  cursor: pointer;
  transition: all var(--t-fast);
  animation: scaleIn 0.2s var(--spring);
}

.react-pill:hover { border-color: var(--accent-cyan); background: rgba(0,229,255,0.06); transform: scale(1.05); }
.react-pill.mine  { border-color: rgba(0,229,255,0.3); background: rgba(0,229,255,0.08); }
.react-pill .cnt  { font-size: 10px; color: var(--text-muted); font-family: var(--font-mono); }

/* ── Audio Bubble ───────────────────────────────── */
.audio-bubble {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-radius: 18px;
  min-width: 210px;
  max-width: 300px;
  cursor: pointer;
  transition: filter var(--t-fast);
}

.msg-row:not(.mine) .audio-bubble {
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-bottom-left-radius: 5px;
}

.msg-row.mine .audio-bubble {
  background: linear-gradient(135deg, var(--accent-cyan), #009bbb);
  border-bottom-right-radius: 5px;
}

.audio-bubble:hover { filter: brightness(1.06); }

.audio-play {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
  transition: all var(--t-fast);
}

.msg-row:not(.mine) .audio-play { background: var(--accent-cyan); color: var(--text-inverse); }
.msg-row.mine .audio-play       { background: rgba(0,0,0,0.2); color: #fff; }
.audio-play:hover { transform: scale(1.08); }
.audio-play.playing { background: var(--accent-orange) !important; }

.audio-wave {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 2px;
  height: 26px;
}

.wbar {
  width: 3px;
  border-radius: 2px;
  min-height: 3px;
  opacity: 0.65;
  transition: height 0.08s;
}

.msg-row:not(.mine) .wbar { background: var(--accent-cyan); }
.msg-row.mine .wbar        { background: rgba(0,0,0,0.4); }

.audio-playing .wbar { animation: wave-bar 0.9s ease-in-out infinite; }
.audio-playing .wbar:nth-child(2n)  { animation-delay: 0.1s; }
.audio-playing .wbar:nth-child(3n)  { animation-delay: 0.2s; }
.audio-playing .wbar:nth-child(4n)  { animation-delay: 0.3s; }
.audio-playing .wbar:nth-child(5n)  { animation-delay: 0.15s; }

.audio-dur {
  font-size: 10px;
  font-family: var(--font-mono);
  opacity: 0.6;
}

/* ── File Bubble ────────────────────────────────── */
.file-bubble {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-radius: 14px;
  max-width: 260px;
  cursor: pointer;
}

.msg-row:not(.mine) .file-bubble {
  background: var(--bg-panel);
  border: 1px solid var(--border);
}

.msg-row.mine .file-bubble {
  background: linear-gradient(135deg, rgba(0,229,255,0.15), rgba(0,153,187,0.15));
  border: 1px solid rgba(0,229,255,0.3);
}

.file-icon-box {
  width: 42px;
  height: 42px;
  border-radius: var(--r-sm);
  background: rgba(0,229,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}

.file-name  { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.file-size  { font-size: 11px; color: var(--text-muted); font-family: var(--font-mono); }

/* ── Typing Indicator ───────────────────────────── */
.typing-indicator {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 11px 16px;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: 18px;
  border-bottom-left-radius: 5px;
  width: fit-content;
  margin-bottom: 10px;
  animation: fadeIn 0.2s ease;
}

.tdot {
  width: 6px;
  height: 6px;
  background: var(--text-muted);
  border-radius: 50%;
  animation: typing-dot 1.3s ease-in-out infinite;
}

.tdot:nth-child(2) { animation-delay: 0.16s; }
.tdot:nth-child(3) { animation-delay: 0.32s; }

/* ══════════════════════════════════════════════════
   INPUT AREA
   ══════════════════════════════════════════════════ */
.input-area {
  padding: 12px 20px 16px;
  background: var(--bg-card);
  border-top: 1px solid var(--border);
  position: relative;
  z-index: 10;
  flex-shrink: 0;
}

/* Reply preview strip */
.reply-strip {
  display: none;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  background: var(--bg-panel);
  border-left: 3px solid var(--accent-cyan);
  border-radius: 0 var(--r-sm) var(--r-sm) 0;
  margin-bottom: 10px;
  animation: fadeIn 0.2s ease;
}

.reply-strip.visible { display: flex; }
.reply-strip-inner { flex: 1; min-width: 0; }
.reply-strip-to    { font-size: 11px; color: var(--accent-cyan); font-weight: 700; margin-bottom: 2px; }
.reply-strip-text  { font-size: 12px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.reply-strip-close { background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 18px; padding: 2px; line-height: 1; transition: color var(--t-fast); }
.reply-strip-close:hover { color: var(--accent-red); }

/* Attachment strip */
.attachment-strip {
  display: none;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  margin-bottom: 10px;
  animation: fadeIn 0.2s ease;
}

.attachment-strip.visible { display: flex; }
.att-icon  { font-size: 22px; }
.att-name  { flex: 1; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.att-size  { font-size: 11px; color: var(--text-muted); font-family: var(--font-mono); }
.att-remove { background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 20px; line-height: 1; transition: color var(--t-fast); }
.att-remove:hover { color: var(--accent-red); }

/* Main input row */
.input-row {
  display: flex;
  align-items: flex-end;
  gap: 9px;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: 24px;
  padding: 8px 8px 8px 14px;
  transition: border-color var(--t-fast), box-shadow var(--t-fast);
}

.input-row:focus-within {
  border-color: var(--accent-cyan);
  box-shadow: 0 0 0 3px rgba(0,229,255,0.06);
}

.input-left {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}

.input-btn-sm {
  width: 34px;
  height: 34px;
  border: none;
  background: transparent;
  color: var(--text-muted);
  cursor: pointer;
  border-radius: var(--r-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19px;
  transition: all var(--t-fast);
}

.input-btn-sm:hover { background: var(--bg-hover); color: var(--text-primary); }

#msg-input {
  flex: 1;
  border: none;
  background: transparent;
  color: var(--text-primary);
  font-family: var(--font-ui);
  font-size: 14px;
  resize: none;
  outline: none;
  max-height: 130px;
  min-height: 24px;
  line-height: 1.5;
  padding: 5px 0;
}

#msg-input::placeholder { color: var(--text-muted); }

.input-right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}

/* Record button */
.rec-btn {
  width: 40px;
  height: 40px;
  border: none;
  background: var(--bg-hover);
  color: var(--text-muted);
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  transition: all var(--t-fast);
  flex-shrink: 0;
}

.rec-btn:hover { background: rgba(255,61,113,0.12); color: var(--accent-red); }
.rec-btn.recording { background: var(--accent-red); color: #fff; animation: record-pulse 1.5s infinite; }

/* Send button */
.send-btn {
  width: 42px;
  height: 42px;
  border: none;
  background: linear-gradient(135deg, var(--accent-cyan), #009bbb);
  color: var(--text-inverse);
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  transition: all var(--t-fast);
  flex-shrink: 0;
  box-shadow: 0 2px 10px rgba(0,229,255,0.25);
}

.send-btn:hover { transform: scale(1.07); box-shadow: var(--glow-cyan); }
.send-btn:active { transform: scale(0.96); }
.send-btn:disabled { opacity: 0.35; cursor: not-allowed; transform: none; box-shadow: none; }

/* Recording UI inside input */
.rec-ui {
  display: none;
  align-items: center;
  gap: 12px;
  flex: 1;
  animation: fadeIn 0.2s ease;
}

.rec-ui.active { display: flex; }

.rec-dot {
  width: 10px;
  height: 10px;
  background: var(--accent-red);
  border-radius: 50%;
  animation: status-blink 0.7s infinite;
  flex-shrink: 0;
}

.rec-timer {
  font-family: var(--font-mono);
  font-size: 14px;
  color: var(--accent-red);
  font-weight: 600;
}

.rec-wave {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 3px;
  height: 32px;
}

.rec-wbar {
  width: 3px;
  background: var(--accent-red);
  border-radius: 2px;
  min-height: 4px;
  opacity: 0.7;
  transition: height 0.07s;
}

.rec-cancel {
  background: none;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  font-size: 20px;
  padding: 3px;
  transition: color var(--t-fast);
  line-height: 1;
}

.rec-cancel:hover { color: var(--accent-red); }

/* Format toolbar */
.format-toolbar {
  display: none;
  gap: 4px;
  padding: 0 4px 8px;
  animation: slideInUp 0.2s ease;
}

.format-toolbar.visible { display: flex; }

.fmt-btn {
  width: 30px;
  height: 30px;
  border: 1px solid var(--border);
  background: var(--bg-panel);
  color: var(--text-secondary);
  border-radius: var(--r-sm);
  cursor: pointer;
  font-size: 13px;
  font-weight: 700;
  transition: all var(--t-fast);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fmt-btn:hover { border-color: var(--accent-cyan); color: var(--accent-cyan); }

/* ══════════════════════════════════════════════════
   EMOJI PICKER
   ══════════════════════════════════════════════════ */
.emoji-picker {
  position: absolute;
  bottom: 84px;
  left: 20px;
  width: 360px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 12px;
  z-index: 200;
  box-shadow: var(--shadow-lg);
  display: none;
  flex-direction: column;
  gap: 10px;
  animation: scaleIn 0.2s var(--spring);
  transform-origin: bottom left;
}

.emoji-picker.open { display: flex; }

.emoji-search {
  width: 100%;
  padding: 9px 14px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  color: var(--text-primary);
  font-family: var(--font-ui);
  font-size: 13px;
  outline: none;
  transition: border-color var(--t-fast);
}

.emoji-search:focus { border-color: var(--accent-cyan); }
.emoji-search::placeholder { color: var(--text-muted); }

.emoji-cats {
  display: flex;
  gap: 4px;
  overflow-x: auto;
  padding-bottom: 2px;
}

.emoji-cats::-webkit-scrollbar { height: 2px; }

.emoji-cat-btn {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border: 1px solid transparent;
  background: var(--bg-panel);
  border-radius: var(--r-sm);
  cursor: pointer;
  font-size: 17px;
  transition: all var(--t-fast);
  display: flex;
  align-items: center;
  justify-content: center;
}

.emoji-cat-btn:hover { background: var(--bg-hover); }
.emoji-cat-btn.on { background: rgba(0,229,255,0.1); border-color: rgba(0,229,255,0.25); }

.emoji-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 4px;
  max-height: 210px;
  overflow-y: auto;
}

.emoji-btn {
  width: 38px;
  height: 38px;
  border: none;
  background: transparent;
  border-radius: var(--r-sm);
  cursor: pointer;
  font-size: 22px;
  transition: all var(--t-fast);
  display: flex;
  align-items: center;
  justify-content: center;
}

.emoji-btn:hover { background: var(--bg-hover); transform: scale(1.18); }

.emoji-recent-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; padding: 0 2px; }

/* ══════════════════════════════════════════════════
   STICKER PICKER
   ══════════════════════════════════════════════════ */
.sticker-picker {
  position: absolute;
  bottom: 84px;
  left: 20px;
  width: 320px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 12px;
  z-index: 200;
  box-shadow: var(--shadow-lg);
  display: none;
  flex-direction: column;
  gap: 10px;
  animation: scaleIn 0.2s var(--spring);
}

.sticker-picker.open { display: flex; }

.sticker-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  max-height: 240px;
  overflow-y: auto;
}

.sticker-btn {
  aspect-ratio: 1;
  border: 1px solid var(--border);
  background: var(--bg-panel);
  border-radius: var(--r-md);
  cursor: pointer;
  font-size: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--t-fast);
}

.sticker-btn:hover { border-color: var(--accent-cyan); transform: scale(1.06); background: rgba(0,229,255,0.05); }

/* ══════════════════════════════════════════════════
   WELCOME SCREEN
   ══════════════════════════════════════════════════ */
.welcome {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
  gap: 20px;
  position: relative;
  z-index: 1;
}

.welcome-icon { font-size: 72px; animation: float 3.5s ease-in-out infinite; }

.welcome-title {
  font-size: 36px;
  font-weight: 800;
  letter-spacing: -1.5px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.welcome-sub { font-size: 14px; color: var(--text-secondary); text-align: center; max-width: 340px; line-height: 1.6; }

.welcome-features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  width: 420px;
  margin-top: 8px;
}

.wf-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 16px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
  transition: border-color var(--t-fast), transform var(--t-fast);
  animation: fadeIn 0.4s ease;
}

.wf-card:hover { border-color: var(--border-active); transform: translateY(-2px); }
.wf-card:nth-child(1) { animation-delay: 0.05s; }
.wf-card:nth-child(2) { animation-delay: 0.10s; }
.wf-card:nth-child(3) { animation-delay: 0.15s; }
.wf-card:nth-child(4) { animation-delay: 0.20s; }
.wf-card:nth-child(5) { animation-delay: 0.25s; }
.wf-card:nth-child(6) { animation-delay: 0.30s; }

.wf-icon  { font-size: 24px; flex-shrink: 0; }
.wf-title { font-size: 12px; font-weight: 700; color: var(--text-primary); margin-bottom: 2px; }
.wf-desc  { font-size: 11px; color: var(--text-muted); line-height: 1.4; }

/* ══════════════════════════════════════════════════
   CALL MODAL
   ══════════════════════════════════════════════════ */
.call-overlay {
  position: fixed;
  inset: 0;
  background: rgba(8,9,13,0.88);
  backdrop-filter: blur(16px);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 800;
}

.call-overlay.open { display: flex; animation: fadeIn 0.3s ease; }

.call-card {
  width: 320px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-xl);
  padding: 48px 36px;
  text-align: center;
  position: relative;
  overflow: hidden;
  animation: scaleIn 0.35s var(--spring);
}

.call-card::before {
  content: '';
  position: absolute;
  top: -60px;
  left: -60px;
  width: 260px;
  height: 260px;
  background: radial-gradient(circle, rgba(0,255,136,0.07) 0%, transparent 70%);
  pointer-events: none;
}

.call-av-wrap {
  display: inline-block;
  position: relative;
  margin-bottom: 22px;
}

.call-ring-1, .call-ring-2, .call-ring-3 {
  position: absolute;
  border-radius: 50%;
  border: 1.5px solid;
  inset: 0;
}

.call-ring-1 { border-color: rgba(0,255,136,0.4); animation: ping 1.8s ease-out infinite; }
.call-ring-2 { border-color: rgba(0,255,136,0.25); animation: ping 1.8s ease-out infinite 0.5s; inset: -14px; }
.call-ring-3 { border-color: rgba(0,255,136,0.12); animation: ping 1.8s ease-out infinite 1s; inset: -28px; }

.call-av {
  width: 88px;
  height: 88px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34px;
  font-weight: 800;
  color: #fff;
  animation: call-pulse 2s infinite;
  position: relative;
  z-index: 1;
}

.call-name   { font-size: 22px; font-weight: 700; margin-bottom: 6px; }
.call-status { font-size: 14px; color: var(--text-secondary); margin-bottom: 10px; }
.call-timer  { font-family: var(--font-mono); font-size: 22px; color: var(--accent-green); margin-bottom: 32px; display: none; }
.call-timer.show { display: block; }

.call-actions { display: flex; justify-content: center; gap: 18px; }

.call-btn {
  width: 58px;
  height: 58px;
  border-radius: 50%;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  transition: all var(--t-fast);
}

.call-btn:hover { transform: scale(1.1); }
.call-btn.answer  { background: var(--accent-green); color: #000; box-shadow: var(--glow-green); }
.call-btn.end     { background: var(--accent-red);   color: #fff; box-shadow: var(--glow-red); }
.call-btn.mute    { background: var(--bg-panel); color: var(--text-secondary); border: 1px solid var(--border); }
.call-btn.mute.on { background: rgba(255,61,113,0.12); color: var(--accent-red); border-color: rgba(255,61,113,0.3); }
.call-btn.speaker { background: var(--bg-panel); color: var(--text-secondary); border: 1px solid var(--border); }
.call-btn.speaker.on { background: rgba(0,229,255,0.1); color: var(--accent-cyan); border-color: rgba(0,229,255,0.3); }

.call-quality {
  margin-top: 16px;
  font-size: 11px;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.quality-bars {
  display: flex;
  align-items: flex-end;
  gap: 2px;
  height: 14px;
}

.qbar {
  width: 3px;
  border-radius: 1px;
  background: var(--accent-green);
}

.qbar:nth-child(1) { height: 4px; }
.qbar:nth-child(2) { height: 8px; }
.qbar:nth-child(3) { height: 12px; }
.qbar.off { background: var(--text-muted); }

/* ══════════════════════════════════════════════════
   INFO PANEL (right)
   ══════════════════════════════════════════════════ */
.info-panel {
  width: var(--info-w);
  min-width: var(--info-w);
  height: 100vh;
  background: var(--bg-card);
  border-left: 1px solid var(--border);
  display: none;
  flex-direction: column;
  overflow-y: auto;
  animation: slideInLeft 0.3s var(--ease-out);
}

.info-panel.open { display: flex; }

.info-header {
  padding: 18px 16px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.info-header-title {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  color: var(--text-muted);
}

.info-banner {
  height: 90px;
  position: relative;
  flex-shrink: 0;
}

.info-av-lg {
  position: absolute;
  bottom: -32px;
  left: 18px;
  border: 4px solid var(--bg-card);
  z-index: 1;
}

.info-body { padding: 44px 18px 18px; }
.info-name { font-size: 19px; font-weight: 700; margin-bottom: 3px; }
.info-handle { font-size: 12px; color: var(--text-muted); font-family: var(--font-mono); }

.info-quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8px;
  margin: 16px 0;
}

.info-qa-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  padding: 10px 6px;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  cursor: pointer;
  font-size: 11px;
  font-weight: 600;
  color: var(--text-secondary);
  font-family: var(--font-ui);
  transition: all var(--t-fast);
}

.info-qa-btn:hover { border-color: var(--accent-cyan); color: var(--accent-cyan); background: rgba(0,229,255,0.04); }
.info-qa-btn-icon { font-size: 20px; }

.info-section { padding: 14px 18px; border-top: 1px solid var(--border); }
.info-section-title { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; color: var(--text-muted); margin-bottom: 12px; }

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 8px 0;
  font-size: 13px;
  color: var(--text-secondary);
}

.info-row-icon { color: var(--text-muted); flex-shrink: 0; margin-top: 1px; }
.info-row-val  { color: var(--text-primary); }

/* Media grid in info panel */
.media-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
}

.media-thumb {
  aspect-ratio: 1;
  background: var(--bg-panel);
  border-radius: var(--r-xs);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  cursor: pointer;
  transition: opacity var(--t-fast);
  overflow: hidden;
}

.media-thumb:hover { opacity: 0.8; }

/* ══════════════════════════════════════════════════
   MODALS
   ══════════════════════════════════════════════════ */
.modal-bg {
  position: fixed;
  inset: 0;
  background: rgba(8,9,13,0.75);
  backdrop-filter: blur(10px);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 600;
}

.modal-bg.open { display: flex; }

.modal {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-xl);
  padding: 32px;
  width: min(440px, 95vw);
  max-height: 90vh;
  overflow-y: auto;
  animation: scaleIn 0.3s var(--spring);
  position: relative;
}

.modal-lg { width: min(600px, 95vw); }

.modal-title { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
.modal-sub   { font-size: 13px; color: var(--text-secondary); margin-bottom: 24px; line-height: 1.5; }

.modal-close {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 30px;
  height: 30px;
  border: none;
  background: var(--bg-panel);
  border-radius: var(--r-full);
  color: var(--text-muted);
  cursor: pointer;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--t-fast);
}

.modal-close:hover { background: var(--bg-hover); color: var(--text-primary); }

.modal-footer {
  display: flex;
  gap: 10px;
  margin-top: 24px;
}

.modal-footer .btn { flex: 1; }

/* ══════════════════════════════════════════════════
   CONTEXT MENU
   ══════════════════════════════════════════════════ */
.ctx-menu {
  position: fixed;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 6px;
  z-index: 900;
  min-width: 175px;
  box-shadow: var(--shadow-lg);
  display: none;
  flex-direction: column;
  gap: 2px;
  animation: scaleIn 0.15s var(--spring);
  transform-origin: top left;
}

.ctx-menu.open { display: flex; }

.ctx-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 12px;
  border-radius: var(--r-sm);
  cursor: pointer;
  font-size: 13px;
  color: var(--text-secondary);
  transition: all var(--t-fast);
  user-select: none;
}

.ctx-item:hover { background: var(--bg-hover); color: var(--text-primary); }
.ctx-item.danger:hover { background: rgba(255,61,113,0.1); color: var(--accent-red); }

.ctx-item-icon { font-size: 16px; width: 20px; text-align: center; }

.ctx-divider { height: 1px; background: var(--border); margin: 4px 0; }

/* Quick reactions row */
.ctx-reactions {
  display: flex;
  gap: 4px;
  padding: 6px 10px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 4px;
}

.ctx-react-btn {
  width: 36px;
  height: 36px;
  border: none;
  background: transparent;
  border-radius: var(--r-sm);
  cursor: pointer;
  font-size: 22px;
  transition: all var(--t-fast);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ctx-react-btn:hover { background: var(--bg-hover); transform: scale(1.2); }

/* ══════════════════════════════════════════════════
   TOAST NOTIFICATIONS
   ══════════════════════════════════════════════════ */
.toast-stack {
  position: fixed;
  top: 16px;
  right: 16px;
  z-index: 9990;
  display: flex;
  flex-direction: column;
  gap: 10px;
  pointer-events: none;
}

.toast {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 14px 18px;
  min-width: 290px;
  max-width: 380px;
  display: flex;
  align-items: flex-start;
  gap: 12px;
  box-shadow: var(--shadow-lg);
  animation: notification-in 0.4s var(--spring);
  pointer-events: all;
  cursor: pointer;
}

.toast.out { animation: notification-out 0.3s var(--ease-in) forwards; }

.toast.success { border-left: 3px solid var(--accent-green); }
.toast.error   { border-left: 3px solid var(--accent-red); }
.toast.info    { border-left: 3px solid var(--accent-cyan); }
.toast.warning { border-left: 3px solid var(--accent-orange); }

.toast-icon { font-size: 22px; flex-shrink: 0; }
.toast-body { flex: 1; }
.toast-title { font-size: 13px; font-weight: 700; margin-bottom: 2px; }
.toast-msg   { font-size: 12px; color: var(--text-secondary); line-height: 1.4; }

/* ══════════════════════════════════════════════════
   SETTINGS PANEL
   ══════════════════════════════════════════════════ */
.settings-section { padding: 14px 0; border-top: 1px solid var(--border); }
.settings-section:first-child { border-top: none; padding-top: 0; }
.settings-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; color: var(--text-muted); margin-bottom: 14px; }

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 0;
}

.setting-label { font-size: 13px; color: var(--text-primary); }
.setting-desc  { font-size: 11px; color: var(--text-muted); margin-top: 1px; }

/* Toggle switch */
.toggle {
  width: 44px;
  height: 25px;
  border-radius: var(--r-full);
  background: var(--bg-hover);
  border: none;
  cursor: pointer;
  position: relative;
  transition: background var(--t-normal);
  flex-shrink: 0;
}

.toggle.on { background: var(--accent-cyan); }

.toggle::after {
  content: '';
  position: absolute;
  top: 3px;
  left: 3px;
  width: 19px;
  height: 19px;
  background: #fff;
  border-radius: 50%;
  transition: transform var(--t-normal) var(--spring);
  box-shadow: 0 1px 4px rgba(0,0,0,0.3);
}

.toggle.on::after { transform: translateX(19px); }

/* Theme selector */
.theme-options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin-top: 10px;
}

.theme-opt {
  aspect-ratio: 1;
  border-radius: var(--r-sm);
  border: 2px solid transparent;
  cursor: pointer;
  transition: all var(--t-fast);
  position: relative;
  overflow: hidden;
}

.theme-opt.selected { border-color: var(--accent-cyan); box-shadow: 0 0 0 2px rgba(0,229,255,0.3); }
.theme-opt:hover { transform: scale(1.05); }

.theme-opt-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.6);
  font-size: 9px;
  text-align: center;
  padding: 3px;
  font-weight: 700;
  color: #fff;
}

/* Status selector */
.status-options {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-top: 10px;
}

.status-opt {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  cursor: pointer;
  transition: all var(--t-fast);
}

.status-opt:hover { background: var(--bg-hover); }
.status-opt.selected { border-color: var(--accent-cyan); background: rgba(0,229,255,0.05); }

.status-opt-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.status-opt-label { font-size: 13px; font-weight: 600; }

/* ══════════════════════════════════════════════════
   STORY VIEWER
   ══════════════════════════════════════════════════ */
.story-viewer {
  position: fixed;
  inset: 0;
  background: #000;
  z-index: 2000;
  display: none;
  flex-direction: column;
}

.story-viewer.open { display: flex; }

.story-progress-bars {
  display: flex;
  gap: 4px;
  padding: 12px 16px 0;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1;
}

.story-pbar {
  flex: 1;
  height: 2px;
  background: rgba(255,255,255,0.3);
  border-radius: 2px;
  overflow: hidden;
}

.story-pbar-fill {
  height: 100%;
  background: #fff;
  border-radius: 2px;
}

.story-pbar-fill.active { animation: progress 5s linear forwards; }
.story-pbar-fill.done   { width: 100%; }

.story-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80px;
  animation: float 2s ease-in-out infinite;
}

.story-nav-left, .story-nav-right {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 40%;
  cursor: pointer;
  z-index: 1;
}

.story-nav-left  { left: 0; }
.story-nav-right { right: 0; }

/* ══════════════════════════════════════════════════
   NOTIFICATION PERMISSION BANNER
   ══════════════════════════════════════════════════ */
.notif-banner {
  background: linear-gradient(135deg, rgba(0,229,255,0.08), rgba(124,58,237,0.08));
  border: 1px solid rgba(0,229,255,0.2);
  border-radius: var(--r-md);
  padding: 12px 16px;
  margin: 12px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  animation: slideInDown 0.3s ease;
}

.notif-banner-icon { font-size: 22px; flex-shrink: 0; }
.notif-banner-text { flex: 1; font-size: 12px; color: var(--text-secondary); line-height: 1.4; }
.notif-banner-text strong { color: var(--text-primary); font-weight: 700; display: block; margin-bottom: 1px; }
.notif-banner-btns { display: flex; gap: 6px; flex-shrink: 0; }

/* ══════════════════════════════════════════════════
   STATUS / CONNECTION INDICATOR
   ══════════════════════════════════════════════════ */
.conn-indicator {
  position: fixed;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-full);
  padding: 8px 16px;
  font-size: 12px;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 8px;
  z-index: 9000;
  box-shadow: var(--shadow-md);
  opacity: 0;
  transition: opacity var(--t-normal);
  pointer-events: none;
}

.conn-indicator.show { opacity: 1; }

/* ══════════════════════════════════════════════════
   EMOJI FLOATING EFFECT
   ══════════════════════════════════════════════════ */
.emoji-float {
  position: fixed;
  font-size: 30px;
  pointer-events: none;
  z-index: 9998;
  animation: emoji-float 1.6s ease forwards;
}

/* ══════════════════════════════════════════════════
   MESSAGE HIGHLIGHT
   ══════════════════════════════════════════════════ */
.msg-row.found .bubble,
.msg-row.found .audio-bubble,
.msg-row.found .file-bubble {
  animation: highlight-flash 2s ease;
}

/* ══════════════════════════════════════════════════
   CONFETTI
   ══════════════════════════════════════════════════ */
.confetti-piece {
  position: fixed;
  width: 10px;
  height: 10px;
  border-radius: 2px;
  pointer-events: none;
  z-index: 9997;
  animation: confetti-drop 3s ease-in forwards;
}

/* ══════════════════════════════════════════════════
   PINNED MESSAGE BAR
   ══════════════════════════════════════════════════ */
.pinned-bar {
  background: rgba(0,229,255,0.04);
  border-bottom: 1px solid rgba(0,229,255,0.15);
  padding: 10px 20px;
  display: none;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  transition: background var(--t-fast);
  z-index: 5;
  position: relative;
}

.pinned-bar.visible { display: flex; }
.pinned-bar:hover   { background: rgba(0,229,255,0.07); }
.pinned-bar-icon    { font-size: 14px; color: var(--accent-cyan); flex-shrink: 0; }
.pinned-bar-content { flex: 1; min-width: 0; }
.pinned-bar-label   { font-size: 10px; font-weight: 700; color: var(--accent-cyan); text-transform: uppercase; letter-spacing: 1px; }
.pinned-bar-text    { font-size: 12px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* ══════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════ */
@media (max-width: 860px) {
  .info-panel { display: none !important; }
}

@media (max-width: 600px) {
  :root { --sidebar-w: 100vw; }

  .sidebar {
    position: absolute;
    inset: 0;
    z-index: 50;
    transition: transform var(--t-normal) var(--ease-out);
  }

  .sidebar.offscreen { transform: translateX(-100%); }

  .auth-wrap { flex-direction: column; height: auto; }
  .auth-left { width: 100%; padding: 30px; }
  .auth-features-list { display: none; }
  .welcome-features { width: 100%; grid-template-columns: 1fr; }
  .call-card { width: 90vw; }
}

/* ══════════════════════════════════════════════════
   TOOLTIP
   ══════════════════════════════════════════════════ */
[data-tip] { position: relative; }

[data-tip]::before {
  content: attr(data-tip);
  position: absolute;
  bottom: calc(100% + 8px);
  left: 50%;
  transform: translateX(-50%);
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  padding: 5px 10px;
  font-size: 11px;
  color: var(--text-primary);
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--t-fast);
  z-index: 100;
  font-family: var(--font-ui);
  font-weight: 600;
}

[data-tip]:hover::before { opacity: 1; }

/* ══════════════════════════════════════════════════
   PROGRESS BAR
   ══════════════════════════════════════════════════ */
.top-loader {
  position: fixed;
  top: 0;
  left: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--accent-cyan), var(--accent-purple));
  border-radius: var(--r-full);
  z-index: 9999;
  transition: width 0.3s ease, opacity 0.3s ease;
  width: 0%;
  opacity: 0;
}

.top-loader.active { opacity: 1; }

/* ══════════════════════════════════════════════════
   GIF PICKER
   ══════════════════════════════════════════════════ */
.gif-picker {
  position: absolute;
  bottom: 84px;
  left: 20px;
  width: 320px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 12px;
  z-index: 200;
  box-shadow: var(--shadow-lg);
  display: none;
  flex-direction: column;
  gap: 10px;
  animation: scaleIn 0.2s var(--spring);
}

.gif-picker.open { display: flex; }

.gif-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
  max-height: 260px;
  overflow-y: auto;
}

.gif-item {
  border-radius: var(--r-sm);
  overflow: hidden;
  cursor: pointer;
  aspect-ratio: 16/9;
  background: var(--bg-panel);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  border: 1px solid var(--border);
  transition: all var(--t-fast);
}

.gif-item:hover { border-color: var(--accent-cyan); transform: scale(1.02); }

/* ══════════════════════════════════════════════════
   CUSTOM STATUS COMPOSER
   ══════════════════════════════════════════════════ */
.status-composer {
  display: flex;
  gap: 10px;
  align-items: center;
  padding: 12px;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  margin-top: 12px;
}

.status-emoji-pick {
  font-size: 26px;
  cursor: pointer;
  transition: transform var(--t-fast);
}

.status-emoji-pick:hover { transform: scale(1.15); }

.status-text-input {
  flex: 1;
  border: none;
  background: transparent;
  color: var(--text-primary);
  font-family: var(--font-ui);
  font-size: 13px;
  outline: none;
}

.status-text-input::placeholder { color: var(--text-muted); }

/* ══════════════════════════════════════════════════
   VOICE NOTE TRANSCRIPT CHIP
   ══════════════════════════════════════════════════ */
.transcript-chip {
  font-size: 11px;
  color: var(--text-muted);
  font-style: italic;
  margin-top: 4px;
  padding: 4px 8px;
  background: var(--bg-panel);
  border-radius: var(--r-sm);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 5px;
}

/* ══════════════════════════════════════════════════
   ENCRYPTION CEREMONY
   ══════════════════════════════════════════════════ */
.enc-ceremony {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 9px 16px;
  background: rgba(0,255,136,0.04);
  border: 1px solid rgba(0,255,136,0.14);
  border-radius: var(--r-md);
  margin: 8px 20px;
  font-size: 11px;
  color: var(--accent-green);
  font-family: var(--font-mono);
  position: relative;
  z-index: 2;
  animation: slideInDown 0.3s ease;
  cursor: pointer;
}

.enc-ceremony-key {
  opacity: 0.55;
  font-size: 10px;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ══════════════════════════════════════════════════
   MISC UTILITIES
   ══════════════════════════════════════════════════ */
.flex     { display: flex; }
.col      { flex-direction: column; }
.items-c  { align-items: center; }
.justify-c{ justify-content: center; }
.justify-b{ justify-content: space-between; }
.gap-1    { gap: 4px; }
.gap-2    { gap: 8px; }
.gap-3    { gap: 12px; }
.gap-4    { gap: 16px; }
.w-full   { width: 100%; }
.flex-1   { flex: 1; }
.truncate { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.hide     { display: none !important; }
.mt-2     { margin-top: 8px; }
.mt-4     { margin-top: 16px; }
.mb-2     { margin-bottom: 8px; }
.mb-4     { margin-bottom: 16px; }
.p-2      { padding: 8px; }
.p-3      { padding: 12px; }
.rounded  { border-radius: var(--r-md); }
.hr       { height: 1px; background: var(--border); margin: 12px 0; }
.mono     { font-family: var(--font-mono); }
.muted    { color: var(--text-muted); }
.secondary{ color: var(--text-secondary); }
.primary  { color: var(--text-primary); }
.cyan     { color: var(--accent-cyan); }
.green    { color: var(--accent-green); }
.red      { color: var(--accent-red); }
.purple   { color: var(--accent-purple); }
</style>
</head>
<body>

<!-- Top loader bar -->
<div class="top-loader" id="top-loader"></div>

<!-- ═══════════════ AUTH SCREEN ═══════════════ -->
<div id="auth-screen">
  <div class="auth-wrap">

