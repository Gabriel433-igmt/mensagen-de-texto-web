async function doLogin() {
  const btn  = document.getElementById('login-btn');
  const user = document.getElementById('l-user').value.trim().toLowerCase();
  const pass = document.getElementById('l-pass').value;
  clearFieldErrors('e-l-user','e-l-pass');

  const userErr = validateUsername(user);
  if (userErr)  { showFieldError('e-l-user', userErr); return; }
  if (!pass)    { showFieldError('e-l-pass', 'Senha obrigatória.'); return; }

  setLoading(btn, true, 'Entrando...');
  startLoader();

  try {
    const data = await fbGet(`users/${user}`);
    if (!data) { showFieldError('e-l-pass', 'Usuário não encontrado.'); return; }

    const hash = await CryptoEngine.hashPw(pass);
    if (data.passwordHash !== hash) { showFieldError('e-l-pass', 'Senha incorreta.'); return; }

    SC.user = { ...data, username: user };
    await fbSet(`users/${user}`, { online: true, lastSeen: Date.now() });
    sessionStorage.setItem('sc_session', JSON.stringify({ username: user }));
    launchApp();

  } catch(e) {
    console.error(e);
    showFieldError('e-l-pass', 'Erro de conexão. Verifique a internet.');
  } finally {
    setLoading(btn, false, '<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"/></svg> Entrar');
    stopLoader();
  }
}

async function doRegister() {
  const btn  = document.getElementById('reg-btn');
  const name = document.getElementById('r-name').value.trim();
  const user = document.getElementById('r-user').value.trim().toLowerCase();
  const pass = document.getElementById('r-pass').value;
  const conf = document.getElementById('r-conf').value;
  clearFieldErrors('e-r-name','e-r-user','e-r-pass','e-r-conf');

  if (!name)          { showFieldError('e-r-name','Nome obrigatório.'); return; }
  if (isBanned(name)) { showFieldError('e-r-name','❌ Nome não permitido.'); return; }
  if (name.length > 40){ showFieldError('e-r-name','Máximo 40 caracteres.'); return; }

  const userErr = validateUsername(user);
  if (userErr)         { showFieldError('e-r-user', userErr); return; }
  if (pass.length < 6) { showFieldError('e-r-pass','Mínimo 6 caracteres.'); return; }
  if (pass !== conf)   { showFieldError('e-r-conf','Senhas não conferem.'); return; }

  setLoading(btn, true, 'Criando conta...');
  startLoader();

  try {
    const existing = await fbGet(`users/${user}`);
    if (existing)      { showFieldError('e-r-user','Usuário já existe.'); return; }

    const passwordHash = await CryptoEngine.hashPw(pass);
    const keyPair      = await CryptoEngine.genKeyPair();
    const publicKey    = await CryptoEngine.exportPub(keyPair.publicKey);

    // Store private key locally only
    const pkcs8 = await crypto.subtle.exportKey('pkcs8', keyPair.privateKey);
    localStorage.setItem(`sc_pk_${user}`, btoa(String.fromCharCode(...new Uint8Array(pkcs8))));

    const color = COLORS[Math.floor(Math.random() * COLORS.length)];

    await fbSet(`users/${user}`, {
      displayName: name,
      username: user,
      passwordHash,
      publicKey,
      avatarColor: color,
      createdAt: Date.now(),
      online: true,
      lastSeen: Date.now(),
      status: 'online',
      statusText: '😊 Usando o SafeChat',
    });

    SC.user = { username: user, displayName: name, publicKey, avatarColor: color };
    sessionStorage.setItem('sc_session', JSON.stringify({ username: user }));
    toast('🎉 Conta criada com sucesso!', 'success');
    launchApp();

  } catch(e) {
    console.error(e);
    showFieldError('e-r-pass','Erro ao criar conta.');
  } finally {
    setLoading(btn, false, '<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg> Criar conta grátis');
    stopLoader();
  }
}

async function doLogout() {
  if (SC.user) {
    await fbSet(`users/${SC.user.username}`, { online: false, lastSeen: Date.now() });
    if (SC.unsubMsgs)   SC.unsubMsgs();
    if (SC.unsubTyping) SC.unsubTyping();
    if (SC.unsubOnline) SC.unsubOnline();
  }
  sessionStorage.removeItem('sc_session');
  SC.user = null;
  SC.chat = null;
  document.getElementById('app').classList.remove('active');
  document.getElementById('app').style.display = 'none';
  document.getElementById('auth-screen').style.display = 'flex';
  toast('Até logo! 👋', 'info');
}

// ══════════════════════════════════════════════════
// APP LAUNCH
// ══════════════════════════════════════════════════
async function launchApp() {
  document.getElementById('auth-screen').style.opacity = '0';
  document.getElementById('auth-screen').style.transition = 'opacity 0.3s ease';

  setTimeout(() => {
    document.getElementById('auth-screen').style.display = 'none';
    const app = document.getElementById('app');
    app.style.display = 'flex';
    app.classList.add('active');
  }, 300);

  applyTheme(SC.theme);
  initMyProfile();
  initEmojiPicker();
  initStickerPicker();
  initGifPicker();
  listenConvs();
  listenOnline();
  checkMobile();
  requestNotifPermission();

  // Apply stored settings to toggles
  syncSettingsUI();

  // Periodic presence ping
  setInterval(() => {
    if (SC.user && !SC.settings.ghost) {
      fbSet(`users/${SC.user.username}`, { online: true, lastSeen: Date.now() });
    }
  }, 25000);

  toast(`Bem-vindo, ${SC.user.displayName || SC.user.username}! 🔐`, 'success');
}

function initMyProfile() {
  const u   = SC.user;
  const av  = document.getElementById('my-av');
  const nm  = document.getElementById('my-name');
  const initials = (u.displayName || u.username).charAt(0).toUpperCase();
  av.textContent = initials;
  av.style.background = u.avatarColor || COLORS[0];
  nm.textContent = u.displayName || u.username;

  // My profile modal
  document.getElementById('mp-av').textContent = initials;
  document.getElementById('mp-av').style.background = u.avatarColor || COLORS[0];
  document.getElementById('mp-name').textContent = u.displayName || u.username;
  document.getElementById('mp-handle').textContent = '@' + u.username;
  document.getElementById('mp-display-name').value = u.displayName || '';
}

function syncSettingsUI() {
  Object.entries(SC.settings).forEach(([k, v]) => {
    const id = `s-${k.replace(/([A-Z])/g,'-$1').toLowerCase()}`;
    const el = document.getElementById(id);
    if (el) el.classList.toggle('on', !!v);
  });
}

// ══════════════════════════════════════════════════
// THEME
// ══════════════════════════════════════════════════
function applyTheme(theme) {
  document.body.className = `theme-${theme}`;
  SC.theme = theme;
  localStorage.setItem('sc_theme', theme);
}

function setTheme(theme, btn) {
  applyTheme(theme);
  document.querySelectorAll('.theme-opt').forEach(o => o.classList.remove('selected'));
  btn.classList.add('selected');
}

// ══════════════════════════════════════════════════
// CONVERSATIONS
// ══════════════════════════════════════════════════
async function listenConvs() {
  await waitFB();
  const { collection, query, onSnapshot, orderBy } = window._fbModules;
  const q = query(collection(window._db, 'chats'));

  onSnapshot(q, snap => {
    const all = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    SC.contacts = all.filter(c =>
      c.participants && c.participants.includes(SC.user.username)
    ).sort((a, b) => (b.lastMessageTime || 0) - (a.lastMessageTime || 0));

    renderConvList(SC.contacts);
    updateTotalUnread();
    renderStories();
  });
}

function renderConvList(convs) {
  const list = document.getElementById('conv-list');
  if (!convs.length) {
    list.innerHTML = `
      <div class="empty">
        <div class="empty-icon">💬</div>
        <div class="empty-title">Sem conversas</div>
        <div class="empty-sub">Clique em <strong>+</strong> para iniciar!</div>
      </div>`;
    return;
  }

  list.innerHTML = '';
  convs.forEach(c => {
    const other  = getOther(c);
    const ci     = colorIndex(other);
    const init   = other.charAt(0).toUpperCase();
    const isActive = SC.chat && SC.chat.id === c.id;
    const unread = (c.unread || {})[SC.user.username] || 0;
    const muted  = SC.mutedConvs.includes(c.id);
    const pinned = (c.pinned || []).includes(SC.user.username);
    const online = !!SC.onlineUsers[other];

    const item = document.createElement('div');
    item.className = `conv-item${isActive?' active':''}${pinned?' pinned':''}`;
    item.dataset.convId = c.id;
    item.onclick = () => openChat(c);

    item.innerHTML = `
      <div class="av av-md ${online?'av-online':'av-offline'}" style="background:${COLORS[ci]};">${init}</div>
      <div class="conv-info">
        <div class="conv-top">
          <div class="conv-name">${esc(other)}</div>
          <div class="conv-time">${c.lastMessageTime ? fmtTime(c.lastMessageTime) : ''}</div>
        </div>
        <div class="conv-bottom">
          <div class="conv-preview${unread?' unread':''}">
            ${c.lastMessage ? '🔒 ' + trunc(c.lastMessage, 28) : '<span class="muted">Sem mensagens</span>'}
          </div>
          ${unread > 0 ? `<div class="conv-badge${muted?' muted':''}">${unread}</div>` : ''}
        </div>
      </div>`;

    list.appendChild(item);
  });
}

function filterConvs(q) {
  const query = q.toLowerCase();
  const filtered = SC.contacts.filter(c => getOther(c).toLowerCase().includes(query));
  renderConvList(filtered);
}

function updateTotalUnread() {
  const total = SC.contacts.reduce((sum, c) => sum + ((c.unread || {})[SC.user.username] || 0), 0);
  const badge = document.getElementById('total-unread-badge');
  if (total > 0) { badge.style.display = 'block'; badge.textContent = total > 99 ? '99+' : total; }
  else             { badge.style.display = 'none'; }
}

function getOther(chat) {
  if (!chat.participants) return chat.name || 'Desconhecido';
  return chat.participants.find(p => p !== SC.user.username) || 'Desconhecido';
}

function colorIndex(str) {
  if (!str) return 0;
  let hash = 0;
  for (let i = 0; i < str.length; i++) hash = (hash << 5) - hash + str.charCodeAt(i);
  return Math.abs(hash) % COLORS.length;
}

// ══════════════════════════════════════════════════
// OPEN CHAT
// ══════════════════════════════════════════════════
async function openChat(chat) {
  SC.chat = chat;
  const other = getOther(chat);
  const ci    = colorIndex(other);

  // UI Switch
  document.getElementById('welcome').style.display = 'none';
  const ac = document.getElementById('active-chat');
  ac.style.display = 'flex';

  // Derive encryption key
  SC.chatKey = await CryptoEngine.fromPassword(chat.id + '_e2e_v2');
  const keyPreview = chat.id.substring(0, 20) + '...';
  document.getElementById('enc-key-text').textContent = keyPreview;
  document.getElementById('enc-modal-key').textContent = chat.id + '_e2e_v2 [SHA-256 → AES-GCM]';

  // Avatar & name
  const av = document.getElementById('chat-av');
  av.textContent = other.charAt(0).toUpperCase();
  av.style.background = COLORS[ci];
  av.style.color = '#fff';
  av.style.fontWeight = '800';
  document.getElementById('chat-name').textContent = other;

  // Status
  const isOnline = !!SC.onlineUsers[other];
  document.getElementById('chat-status').textContent = isOnline ? 'Online' : 'Offline';
  document.getElementById('hdr-status-dot').style.background = isOnline ? 'var(--accent-green)' : 'var(--text-muted)';

  // Info panel
  updateInfoPanel(other);

  // Pinned message
  if (SC.pinnedMsgId && SC.pinnedMsgText) {
    document.getElementById('pinned-bar').classList.add('visible');
    document.getElementById('pinned-text').textContent = SC.pinnedMsgText;
  }

  // Clear unread
  if ((chat.unread || {})[SC.user.username] > 0) {
    const unread = { ...(chat.unread || {}), [SC.user.username]: 0 };
    fbSet(`chats/${chat.id}`, { unread });
  }

  // Listen messages
  listenMessages(chat.id);
  listenTyping(chat.id);

  renderConvList(SC.contacts);

  // Mobile
  if (window.innerWidth <= 600) {
    document.getElementById('sidebar').classList.add('offscreen');
    document.getElementById('back-btn').style.display = 'flex';
  }
}

function goBackMobile() {
  document.getElementById('sidebar').classList.remove('offscreen');
  document.getElementById('back-btn').style.display = 'none';
}

// ══════════════════════════════════════════════════
// MESSAGES
// ══════════════════════════════════════════════════
async function listenMessages(chatId) {
  if (SC.unsubMsgs) SC.unsubMsgs();
  await waitFB();
  const { collection, query, orderBy, onSnapshot } = window._fbModules;
  const q = query(collection(window._db, `chats/${chatId}/messages`), orderBy('timestamp','asc'));

  SC.unsubMsgs = onSnapshot(q, async snap => {
    const msgs = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    SC.messages = msgs;
    await renderMessages(msgs, chatId);
    scrollToBottom();
  });
}

async function renderMessages(msgs, chatId) {
  const container = document.getElementById('msgs');
  container.innerHTML = '';
  let lastDate = null;

  for (const msg of msgs) {
    const d = new Date(msg.timestamp || Date.now());
    const dateStr = d.toLocaleDateString('pt-BR', { day:'2-digit', month:'long', year:'numeric' });

    if (dateStr !== lastDate) {
      container.appendChild(mkDateSep(dateStr));
      lastDate = dateStr;
    }

    const el = await buildMsgEl(msg, chatId);
    container.appendChild(el);
  }
}

async function buildMsgEl(msg, chatId) {
  const mine  = msg.sender === SC.user.username;
  const other = getOther(SC.chat);
  const ci    = colorIndex(msg.sender);
  const row   = document.createElement('div');
  row.className = `msg-row${mine?' mine':''}`;
  row.dataset.msgId = msg.id;
  row.addEventListener('contextmenu', e => { e.preventDefault(); showCtxMenu(e, msg, mine); });

  // Avatar
  const av = document.createElement('div');
  av.className = 'av av-sm';
  av.style.background = COLORS[ci];
  av.style.color = '#fff';
  av.style.fontWeight = '800';
  av.style.fontSize = '12px';
  av.textContent = (msg.sender || '?').charAt(0).toUpperCase();

  const group = document.createElement('div');
  group.className = 'msg-group';

  if (!mine) {
    const sl = document.createElement('div');
    sl.className = 'msg-sender-label';
    sl.textContent = msg.sender;
    group.appendChild(sl);
  }

  // Build content by type
  let content;
  if (msg.type === 'audio') {
    content = buildAudioEl(msg, mine);
  } else if (msg.type === 'file') {
    content = buildFileEl(msg, mine);
  } else if (msg.type === 'sticker') {
    content = document.createElement('div');
    content.style.cssText = 'font-size:56px;padding:4px 6px;line-height:1;cursor:pointer;';
    content.textContent = msg.text || '🎨';
  } else {
    content = document.createElement('div');
    let displayText = msg.text || '';

    // Decrypt
    if (msg.encrypted && SC.chatKey) {
      try { displayText = await CryptoEngine.decrypt(msg.text, SC.chatKey); }
      catch { displayText = '🔒'; }
    }

    const isEmoji = /^\p{Emoji}+$/u.test(displayText.trim()) && displayText.trim().length <= 12;
    content.className = `bubble${isEmoji?' only-emoji':''}`;

    // Reply inside bubble
    if (msg.replyTo) {
      const rp = document.createElement('div');
      rp.className = 'bubble-reply';
      rp.innerHTML = `<div class="bubble-reply-sender">${esc(msg.replyTo.sender)}</div>${esc(trunc(msg.replyTo.text||'',50))}`;
      content.appendChild(rp);
    }

    const textNode = document.createElement('div');
    textNode.innerHTML = fmtMsg(displayText) + (msg.encrypted ? ' <span class="msg-encrypted-badge">🔒</span>' : '');
    content.appendChild(textNode);
  }

  group.appendChild(content);

  // Reactions
  if (msg.reactions && Object.keys(msg.reactions).length > 0) {
    const rRow = document.createElement('div');
    rRow.className = 'msg-reactions';
    const grouped = {};
    Object.entries(msg.reactions).forEach(([uid, r]) => { grouped[r] = (grouped[r] || []).concat(uid); });
    Object.entries(grouped).forEach(([emoji, users]) => {
      const pill = document.createElement('div');
      pill.className = `react-pill${users.includes(SC.user.username)?' mine':''}`;
      pill.innerHTML = `${emoji}<span class="cnt">${users.length}</span>`;
      pill.onclick = () => addReaction(msg.id, emoji);
      rRow.appendChild(pill);
    });
    group.appendChild(rRow);
  }

  // Footer (time + read tick)
  const foot = document.createElement('div');
  foot.className = 'msg-footer';
  foot.innerHTML = `${fmtTime(msg.timestamp||Date.now())}${mine&&SC.settings.readReceipt?'<span class="tick read">✓✓</span>':''}`;
  group.appendChild(foot);

  // Starred badge
  if (SC.starredMessages.includes(msg.id)) {
    const star = document.createElement('div');
    star.style.cssText = 'font-size:11px;color:var(--accent-yellow);padding:0 4px;';
    star.textContent = '⭐';
    group.appendChild(star);
  }

  if (!mine) row.appendChild(av);
  row.appendChild(group);
  if (mine)  row.appendChild(av);

  if (SC.settings.animations) row.style.animation = 'msgIn 0.25s var(--spring)';

  return row;
}

function buildAudioEl(msg, mine) {
  const wrap = document.createElement('div');
  wrap.className = 'audio-bubble';
  wrap.id = `ab-${msg.id}`;

  const heights = [3,6,10,14,18,16,12,10,14,18,16,12,8,10,14,16,12,8,5,3];
  const bars = heights.map(h => `<div class="wbar" style="height:${h}px"></div>`).join('');

  wrap.innerHTML = `
    <button class="audio-play" onclick="playAudio('${msg.id}','${msg.audioUrl||''}',this)">▶</button>
    <div class="audio-wave">${bars}</div>
    <span class="audio-dur">${msg.duration||'0:00'}</span>`;
  return wrap;
}

function buildFileEl(msg, mine) {
  const wrap = document.createElement('div');
  wrap.className = 'file-bubble';

  const ext = (msg.fileName||'').split('.').pop().toUpperCase();
  const icon = { PDF:'📄', MP4:'📹', MP3:'🎵', JPG:'🖼️', PNG:'🖼️', ZIP:'📦', DOCX:'📝' }[ext] || '📎';

  wrap.innerHTML = `
    <div class="file-icon-box">${icon}</div>
    <div>
      <div class="file-name">${esc(trunc(msg.fileName||'Arquivo',24))}</div>
      <div class="file-size">${fmtSize(msg.fileSize||0)} · ${ext}</div>
    </div>`;
  return wrap;
}

function mkDateSep(label) {
  const div = document.createElement('div');
  div.className = 'date-sep';
  div.innerHTML = `<div class="date-sep-line"></div><div class="date-sep-label">${label}</div><div class="date-sep-line"></div>`;
  return div;
}

function playAudio(msgId, url, btn) {
  if (!url) { toast('Áudio não disponível.','error'); return; }
  const wrap = document.getElementById(`ab-${msgId}`);
  let audio = document.getElementById(`aud-${msgId}`);

  if (!audio) {
    audio = new Audio(url);
    audio.id = `aud-${msgId}`;
    audio.onended = () => { btn.textContent = '▶'; wrap.classList.remove('audio-playing'); btn.classList.remove('playing'); };
  }

  if (btn.classList.contains('playing')) {
    audio.pause();
    btn.textContent = '▶';
    wrap.classList.remove('audio-playing');
    btn.classList.remove('playing');
  } else {
    audio.play();
    btn.textContent = '⏸';
    wrap.classList.add('audio-playing');
    btn.classList.add('playing');
  }
}

// ══════════════════════════════════════════════════
// SEND MESSAGE
// ══════════════════════════════════════════════════
async function sendMessage() {
  const inp  = document.getElementById('msg-input');
  const text = inp.value.trim();

  if (!text && !SC.pendingFile) return;
  if (text && !validateMessage(text)) return;
  if (!SC.chat) return;

  const btn = document.getElementById('send-btn');
  btn.disabled = true;

  try {
    let data = {
      sender: SC.user.username,
      timestamp: Date.now(),
      type: 'text',
      encrypted: true,
    };

    if (text) {
      data.text = SC.chatKey ? await CryptoEngine.encrypt(text, SC.chatKey) : text;
    }

    if (SC.replyTo) {
      data.replyTo = { id: SC.replyTo.id, sender: SC.replyTo.sender, text: trunc(SC.replyTo.text||'',60) };
    }

    if (SC.pendingFile) {
      data.type     = 'file';
      data.fileName = SC.pendingFile.name;
      data.fileSize = SC.pendingFile.size;
      data.text     = '';
      data.encrypted = false;
    }

    await fbAdd(`chats/${SC.chat.id}/messages`, data);

    const other = getOther(SC.chat);
    const unread = { ...(SC.chat.unread||{}), [other]: ((SC.chat.unread||{})[other]||0) + 1 };
    await fbSet(`chats/${SC.chat.id}`, {
      lastMessage: text ? text.substring(0,60) : SC.pendingFile?.name || 'Arquivo',
      lastMessageTime: Date.now(),
      unread,
    });

    inp.value = '';
    inp.style.height = 'auto';
    btn.disabled = true;
    cancelReply();
    removeFile();
    stopTypingIndicator();

    // Emoji float effect
    if (/^\p{Emoji}+$/u.test(text.trim()) && text.trim().length <= 8) {
      floatEmoji(text.trim());
    }

    // Play send sound
    if (SC.settings.sound) playSendSound();

    // Update recent emojis
    const emojiMatches = text.match(/\p{Emoji}/gu);
    if (emojiMatches) {
      emojiMatches.forEach(e => {
        SC.recentEmojis = [e, ...SC.recentEmojis.filter(x => x !== e)].slice(0, 16);
      });
      localStorage.setItem('sc_recent_emojis', JSON.stringify(SC.recentEmojis));
    }

  } catch(e) {
    console.error(e);
    toast('Erro ao enviar mensagem.', 'error');
  } finally {
    setTimeout(() => {
      if (!inp.value.trim()) btn.disabled = true;
    }, 50);
  }
}

function onMsgInput(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 130) + 'px';
  document.getElementById('send-btn').disabled = el.value.trim() === '' && !SC.pendingFile;
  handleTypingEvent();
}

function onMsgKey(e) {
  if (e.key === 'Enter' && !e.shiftKey && SC.settings.enterSend) {
    e.preventDefault();
    if (!document.getElementById('send-btn').disabled) sendMessage();
  }
}

// ══════════════════════════════════════════════════
// TYPING
// ══════════════════════════════════════════════════
async function handleTypingEvent() {
  if (!SC.chat || !SC.settings.showTyping) return;
  fbSet(`chats/${SC.chat.id}/typing/${SC.user.username}`, { t: true, at: Date.now() });
  clearTimeout(SC.typingTimeout);
  SC.typingTimeout = setTimeout(stopTypingIndicator, TYPING_DELAY);
}

async function stopTypingIndicator() {
  if (!SC.chat) return;
  fbSet(`chats/${SC.chat.id}/typing/${SC.user.username}`, { t: false });
}

async function listenTyping(chatId) {
  if (SC.unsubTyping) SC.unsubTyping();
  await waitFB();
  const { collection, onSnapshot } = window._fbModules;

  SC.unsubTyping = onSnapshot(collection(window._db, `chats/${chatId}/typing`), snap => {
    const isTyping = snap.docs.some(d =>
      d.id !== SC.user.username && d.data().t === true && (Date.now() - d.data().at) < 3000
    );
    document.getElementById('typing-row').style.display = isTyping ? 'block' : 'none';
  });
}

// ══════════════════════════════════════════════════
// AUDIO RECORDING
// ══════════════════════════════════════════════════
async function toggleRec() {
  SC.isRecording ? stopRec() : startRec();
}

async function startRec() {
  try {
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    SC.mediaRecorder = new MediaRecorder(stream);
    SC.audioChunks   = [];

    SC.mediaRecorder.ondataavailable = e => SC.audioChunks.push(e.data);
    SC.mediaRecorder.onstop = () => processAudio(stream);
    SC.mediaRecorder.start();
    SC.isRecording = true;

    document.getElementById('rec-btn').classList.add('recording');
    document.getElementById('normal-row').style.display = 'none';
    document.getElementById('rec-ui').classList.add('active');

    SC.recSecs = 0;
    SC.recTimer = setInterval(() => {
      SC.recSecs++;
      const m = Math.floor(SC.recSecs/60);
      const s = SC.recSecs % 60;
      document.getElementById('rec-timer').textContent = `${m}:${s.toString().padStart(2,'0')}`;
    }, 1000);

    animateRecWave();
    toast('🎙️ Gravando... Clique novamente para parar.', 'info');

  } catch(e) {
    toast('❌ Microfone não disponível.', 'error');
  }
}

function animateRecWave() {
  const wave = document.getElementById('rec-wave');
  wave.innerHTML = '';
  for (let i = 0; i < 28; i++) {
    const b = document.createElement('div');
    b.className = 'rec-wbar';
    b.style.height = '4px';
    wave.appendChild(b);
  }

  const tick = () => {
    if (!SC.isRecording) return;
    wave.querySelectorAll('.rec-wbar').forEach(b => {
      b.style.height = (Math.random() * 22 + 4) + 'px';
    });
    requestAnimationFrame(() => setTimeout(tick, 75));
  };
  tick();
}

function stopRec() {
  if (SC.mediaRecorder && SC.mediaRecorder.state !== 'inactive') {
    SC.mediaRecorder.stop();
  }
  SC.isRecording = false;
  clearInterval(SC.recTimer);
  document.getElementById('rec-btn').classList.remove('recording');
  document.getElementById('normal-row').style.display = 'flex';
  document.getElementById('rec-ui').classList.remove('active');
}

function cancelRec() {
  if (SC.mediaRecorder) {
    SC.mediaRecorder.ondataavailable = null;
    SC.mediaRecorder.onstop = null;
    if (SC.mediaRecorder.state !== 'inactive') SC.mediaRecorder.stop();
  }
  SC.isRecording = false;
  SC.audioChunks = [];
  clearInterval(SC.recTimer);
  document.getElementById('rec-btn').classList.remove('recording');
  document.getElementById('normal-row').style.display = 'flex';
  document.getElementById('rec-ui').classList.remove('active');
  toast('Gravação cancelada.', 'warning');
}

async function processAudio(stream) {
  stream.getTracks().forEach(t => t.stop());
  if (!SC.audioChunks.length) return;

  const blob = new Blob(SC.audioChunks, { type:'audio/webm' });
  const url  = URL.createObjectURL(blob);
  const dur  = `${Math.floor(SC.recSecs/60)}:${(SC.recSecs%60).toString().padStart(2,'0')}`;

  await fbAdd(`chats/${SC.chat.id}/messages`, {
    sender: SC.user.username,
    timestamp: Date.now(),
    type: 'audio',
    audioUrl: url,
    duration: dur,
    encrypted: false,
  });

  await fbSet(`chats/${SC.chat.id}`, {
    lastMessage: '🎙️ Mensagem de voz',
    lastMessageTime: Date.now(),
  });

